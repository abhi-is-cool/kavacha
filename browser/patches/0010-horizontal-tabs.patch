         appContentNavbarContaienr.append(windowButtons);
       }
 
+      // Kavacha horizontal mode (patch 0010): Chrome-convention layout.
+      // The single-toolbar shuffle above sends the nav buttons and the
+      // macOS traffic lights to zen-sidebar-top-buttons (the URL row's
+      // right end, where the full-width urlbar paints over the lights).
+      // Re-assert our layout every update: back/forward/reload on the
+      // urlbar's left, traffic lights in the tab strip row (macOS
