diff --git a/src/zen/kavacha-newtab/newtab.css b/src/zen/kavacha-newtab/newtab.css
new file mode 100644
index 0000000..6624015
--- /dev/null
+++ b/src/zen/kavacha-newtab/newtab.css
@@ -0,0 +1,257 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/* Kavacha dashboard new tab — calm Momentum-style layout, fully offline:
+   gradient of the day, clock, greeting, bundled quote. No network, ever. */
+
+*,
+*::before,
+*::after {
+  box-sizing: border-box;
+  margin: 0;
+}
+
+html,
+body {
+  height: 100%;
+}
+
+body {
+  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
+    Helvetica, Arial, sans-serif;
+  color: #fff;
+  background: #1c1d22;
+  overflow: hidden;
+  -webkit-font-smoothing: antialiased;
+}
+
+.hidden {
+  display: none !important;
+}
+
+/* ---- gradient background ---- */
+.bg {
+  position: fixed;
+  inset: 0;
+  z-index: -1;
+  opacity: 0;
+  transition: opacity 0.8s ease;
+  /* set from JS: --g1..--g3 palette stops */
+  background:
+    radial-gradient(
+      ellipse 120% 80% at 70% 10%,
+      var(--g2, #2b3a55) 0%,
+      transparent 60%
+    ),
+    radial-gradient(
+      ellipse 100% 90% at 15% 95%,
+      var(--g3, #16324f) 0%,
+      transparent 55%
+    ),
+    linear-gradient(160deg, var(--g1, #1c2733) 0%, var(--g4, #0d1420) 100%);
+}
+
+.bg.loaded {
+  opacity: 1;
+}
+
+/* ---- Wikimedia photo of the day (fades in over the gradient) ---- */
+.photo {
+  position: fixed;
+  inset: 0;
+  z-index: -1;
+  background-size: cover;
+  background-position: center;
+  opacity: 0;
+  transition: opacity 1.2s ease;
+}
+
+.photo.loaded {
+  opacity: 1;
+}
+
+/* gentle darkening so text stays legible on any photo */
+.scrim {
+  position: fixed;
+  inset: 0;
+  z-index: -1;
+  background: linear-gradient(
+    180deg,
+    rgba(0, 0, 0, 0.35) 0%,
+    rgba(0, 0, 0, 0.05) 35%,
+    rgba(0, 0, 0, 0.05) 60%,
+    rgba(0, 0, 0, 0.45) 100%
+  );
+}
+
+.credit {
+  position: fixed;
+  bottom: 1rem;
+  right: 1.4rem;
+  font-size: 0.8rem;
+  color: rgba(255, 255, 255, 0.75);
+  text-decoration: none;
+  text-shadow: 0 1px 10px rgba(0, 0, 0, 0.6);
+  max-width: 44vw;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+  transition: color 0.2s;
+}
+
+.credit:hover {
+  color: #fff;
+}
+
+/* ---- onboarding ---- */
+.onboarding {
+  position: fixed;
+  inset: 0;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  animation: fade 0.6s ease;
+}
+
+.name-form {
+  text-align: center;
+  width: min(90vw, 640px);
+}
+
+.name-label {
+  display: block;
+  font-size: clamp(1.6rem, 4vw, 3rem);
+  font-weight: 600;
+  margin-bottom: 1.2rem;
+  text-shadow: 0 1px 14px rgba(0, 0, 0, 0.4);
+}
+
+.name-input {
+  width: 100%;
+  background: transparent;
+  border: none;
+  border-bottom: 2px solid rgba(255, 255, 255, 0.55);
+  color: #fff;
+  text-align: center;
+  font-size: clamp(1.4rem, 3.5vw, 2.4rem);
+  font-weight: 600;
+  padding: 0.4rem 0.2rem;
+  outline: none;
+}
+
+.name-input::placeholder {
+  color: rgba(255, 255, 255, 0.5);
+  font-size: 1rem;
+}
+
+.name-skip {
+  margin-top: 1.6rem;
+  background: transparent;
+  border: none;
+  color: rgba(255, 255, 255, 0.6);
+  font-size: 0.95rem;
+  cursor: pointer;
+  padding: 0.4rem 1rem;
+}
+
+.name-skip:hover {
+  color: #fff;
+}
+
+/* ---- dashboard ---- */
+.dash {
+  position: fixed;
+  inset: 0;
+  display: flex;
+  flex-direction: column;
+  align-items: center;
+  justify-content: center;
+  padding: 4rem 2rem;
+  animation: fade 0.8s ease;
+}
+
+.center {
+  text-align: center;
+}
+
+.clock {
+  font-size: clamp(4rem, 13vw, 9rem);
+  font-weight: 600;
+  letter-spacing: 0.01em;
+  text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
+  font-variant-numeric: tabular-nums;
+}
+
+.greeting {
+  font-size: clamp(1.4rem, 4vw, 2.4rem);
+  font-weight: 600;
+  margin-top: 0.4rem;
+  text-shadow: 0 1px 16px rgba(0, 0, 0, 0.4);
+  cursor: text;
+}
+
+.greeting .name {
+  border-bottom: 1px dashed transparent;
+  transition: border-color 0.2s;
+}
+
+.greeting:hover .name {
+  border-bottom-color: rgba(255, 255, 255, 0.5);
+}
+
+/* ---- quote ---- */
+.quote {
+  position: fixed;
+  left: 50%;
+  bottom: 3.2rem;
+  transform: translateX(-50%);
+  width: min(90vw, 720px);
+  text-align: center;
+  text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45);
+  animation: fade 1.2s ease;
+}
+
+.quote blockquote {
+  font-size: clamp(1rem, 2.2vw, 1.35rem);
+  font-weight: 500;
+  line-height: 1.5;
+  font-style: italic;
+}
+
+.quote figcaption {
+  margin-top: 0.6rem;
+  font-size: 0.95rem;
+  opacity: 0.85;
+  font-style: normal;
+}
+
+.quote figcaption::before {
+  content: "\2014\00a0"; /* em dash */
+}
+
+@keyframes fade {
+  from {
+    opacity: 0;
+  }
+
+  to {
+    opacity: 1;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .bg,
+  .onboarding,
+  .dash,
+  .quote {
+    transition: none;
+    animation: none;
+  }
+}
+
+@media (max-width: 640px) {
+  .quote {
+    display: none;
+  }
+}
diff --git a/src/zen/kavacha-newtab/newtab.js b/src/zen/kavacha-newtab/newtab.js
new file mode 100644
index 0000000..daddd6b
--- /dev/null
+++ b/src/zen/kavacha-newtab/newtab.js
@@ -0,0 +1,288 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// Kavacha dashboard new tab. Everything is local: gradient of the day,
+// clock, greeting, and a quote from the bundled list. No network requests.
+
+"use strict";
+
+const $ = id => document.getElementById(id);
+
+// Local (YYYY-M-D) key so the day rolls over at local midnight, not UTC.
+const now = new Date();
+const dateKey = `${now.getFullYear()}-${now.getMonth() + 1}-${now.getDate()}`;
+
+// Small deterministic string hash for stable picks of the day.
+function hash(str) {
+  let h = 0;
+  for (let i = 0; i < str.length; i++) {
+    h = (h << 5) - h + str.charCodeAt(i);
+    h |= 0;
+  }
+  return Math.abs(h);
+}
+
+/* ---------------------------------------------------------------- storage
+   The page is served from chrome:// and may run with the system principal,
+   where DOM storage is unavailable — fall back to the pref service, which
+   privileged pages can reach. Either way the name never leaves the profile. */
+const store = (() => {
+  try {
+    const k = "__kavacha_probe__";
+    localStorage.setItem(k, "1");
+    localStorage.removeItem(k);
+    return {
+      get: k => localStorage.getItem(k),
+      set: (k, v) => localStorage.setItem(k, v),
+    };
+  } catch (e) {
+    // fall through
+  }
+  try {
+    const prefs = Services.prefs;
+    const P = "kavacha.newtab.";
+    return {
+      get: k => (prefs.prefHasUserValue(P + k) ? prefs.getStringPref(P + k) : null),
+      set: (k, v) => prefs.setStringPref(P + k, String(v)),
+    };
+  } catch (e) {
+    const mem = {};
+    return { get: k => mem[k] ?? null, set: (k, v) => (mem[k] = v) };
+  }
+})();
+
+/* ------------------------------------------------------------------- name */
+function firstName() {
+  const n = store.get("name") || "";
+  return n.trim().split(/\s+/)[0] || "";
+}
+
+function showOnboarding() {
+  $("dash").classList.add("hidden");
+  $("onboarding").classList.remove("hidden");
+  const input = $("name-input");
+  input.value = store.get("name") || "";
+  input.focus();
+  input.select();
+}
+
+function startDashboard() {
+  $("onboarding").classList.add("hidden");
+  $("dash").classList.remove("hidden");
+  tick();
+  renderGreeting();
+}
+
+/* --------------------------------------------------------------- greeting */
+function greetingWord(h) {
+  if (h < 12) {
+    return "Good Morning";
+  }
+  if (h < 18) {
+    return "Good Afternoon";
+  }
+  return "Good Evening";
+}
+
+function renderGreeting() {
+  const word = greetingWord(new Date().getHours());
+  const name = firstName();
+  const el = $("greeting");
+  el.textContent = "";
+  if (name) {
+    el.append(`${word}, `);
+    const span = document.createElement("span");
+    span.className = "name";
+    span.textContent = name;
+    el.append(span, ".");
+  } else {
+    el.append(`${word}.`);
+  }
+}
+
+/* ------------------------------------------------------------------ clock */
+function tick() {
+  const d = new Date();
+  let h = d.getHours();
+  const m = String(d.getMinutes()).padStart(2, "0");
+  h = h % 12 || 12;
+  $("clock").textContent = `${h}:${m}`;
+}
+setInterval(() => {
+  tick();
+  renderGreeting();
+}, 15000);
+
+/* ------------------------------------------------------------- background
+   Gradient of the day: four-stop palettes tuned for white text. Bundled
+   photos were considered and dropped — the Momentum catalog is not
+   redistributable — so the look is generated, weighs nothing, and never
+   needs the network. */
+const PALETTES = [
+  { g1: "#1c2733", g2: "#2b3a55", g3: "#16324f", g4: "#0d1420" }, // harbor night
+  { g1: "#2d1b3d", g2: "#5c2a5e", g3: "#31214f", g4: "#140d20" }, // dusk violet
+  { g1: "#0f2b26", g2: "#1e4d3a", g3: "#123a33", g4: "#081512" }, // deep forest
+  { g1: "#33261b", g2: "#7a4a2b", g3: "#4f3121", g4: "#170f0a" }, // ember
+  { g1: "#12303e", g2: "#20647a", g3: "#154254", g4: "#081820" }, // fjord
+  { g1: "#251f38", g2: "#3d3a6e", g3: "#2a2452", g4: "#0f0c1c" }, // late aurora
+  { g1: "#30222c", g2: "#6e3a52", g3: "#472a3e", g4: "#150d12" }, // plum dawn
+  { g1: "#1f2a20", g2: "#3f5c35", g3: "#2b4029", g4: "#0d130d" }, // meadow dark
+  { g1: "#222b36", g2: "#46607a", g3: "#2e4257", g4: "#0e141b" }, // north sea
+  { g1: "#2e2617", g2: "#6b5a25", g3: "#463c1c", g4: "#14100a" }, // golden hour
+  { g1: "#101f33", g2: "#274a7a", g3: "#1a3355", g4: "#070e18" }, // midnight blue
