# Patch 0010 — Horizontal tabs mode (functional; Kavacha default).
#
# Zen's JS supports horizontal orientation (zen.tabs.vertical=false) but its
# CSS hard-codes the vertical sidebar and its workspace markup hardcodes
# orient="vertical" on the tab scrollbox. This patch restores a working
# top-bar layout, gated entirely on @media not -moz-pref("zen.tabs.vertical")
# plus one pref check — zero effect when the pref is true.
#
# Functionally verified via Marionette automation (2026-07-13): tabs render
# horizontally (favicons/titles, correct sizes), click-selection, URL bar
# typing + navigation, web content fills the window, new-tab behavior, and
# workspace create/switch with correct tab swapping all work.
# Key fixes, for future maintenance:
#   - row layout needs flex bases vertical mode never set (toolbar-items,
#     tabs container, tabs wrapper)
#   - foot-buttons + essentials carried min-width:100% from the sidebar and
#     starved the row
#   - the sidebar resize splitter stays in flow and eats the window column —
#     content collapses to 0 height unless it's hidden
#   - the workspace scrollbox markup hardcodes orient="vertical", which is
#     forwarded into shadow DOM where CSS can't reach — ZenSpace.mjs now sets
#     it from the pref at connect time
# Remaining polish: active-tab visual emphasis, strip spacing/borders,
# multi-space icon strip placement — track in ROADMAP Phase 3.
# Touches: src/zen/tabs/zen-tabs.css (adds %include),
#          src/zen/tabs/zen-tabs/kavacha-horizontal-tabs.inc.css (new),
#          src/zen/spaces/ZenSpace.mjs (orient from pref).
# Applies on top of 0009.
# Multi-space fix (same day): the space icon strip collapsed to 0 width in
# horizontal (width:100% of an auto-width parent + container-type:
# inline-size making intrinsic sizing ignore the icons) — no visible
# switcher. Now sized to content; icon-click switching Marionette-verified
# with tabs swapping correctly.
# Real-profile fixes (verified against a copy of a real multi-space profile
# with container spaces + essentials): per-container essentials sections are
# hidden via position:fixed — the blanket static override dragged empty
# hidden sections into the strip as stacked 44px rows; now scoped to
# :not([hidden]) with hidden sections display:none, and essentials render
# as 36px favicon squares inline.
# Startup-space fix (the "my tabs never show" bug): ZenStartup.mjs ends
# startup by unconditionally setting the active workspace's scrollbox back
# to orient="vertical" ("a bit of a hack") — overriding the per-workspace
# orient fix for exactly the space active at launch. Now follows the pref.
# Also: .toolbar-items carries XUL align="end", so an oversized child
# inflates the strip row and sinks the tab area below the clip — the row is
# now capped at one strip-height and center-aligned. Verified on a copy of
# a real profile: all spaces show tabs in-strip at startup and across
# switches.
# Chrome-convention pass (user feedback): tab strip is the TOP row (padded
# for macOS traffic lights, whose stale reservation in the buttons row is
# dropped), URL bar row below shares its line with the app-menu/extensions
# buttons via wrapping row flex. Sidebar notifications (e.g. the
# post-update card, previously an unclosable sliver in the strip) float as
# a fixed dismissable card. Verified: all spaces populate the top strip
# across switches; Gmail loads and renders.
# URL-row refinement (user feedback): edge padding; nav buttons
# (back/forward) moved INTO the nav bar left of the URL bar at startup
# (ZenStartup, horizontal only); URL bar un-capped (Zen's min(90%,62rem)
# float width) and filling the row; app menu/extensions right. macOS
# traffic lights: the buttonbox must be MOVED into the tab strip row in
# normal flow — position:fixed makes Cocoa ghost multiple button sets, and
# display:none hides the native buttons entirely (they are positioned from
# this element's geometry).
# URL-row hardening (2026-07-13, user-reported regressions):
#   - The Chrome-convention moves now live at the END of _updateEvent in
#     ZenUIManager.mjs (not just ZenStartup) — Zen's single-toolbar shuffle
#     re-sent nav buttons and the macOS traffic lights to the row's right on
#     every layout event; re-asserting inside _updateEvent survives them.
#   - The urlbar is a top-layer POPOVER: Firefox syncs width via a
#     ResizeObserver on #urlbar-container and x/y from the DOM slot's static
#     position. Never pin its geometry from CSS (resolves against the
#     viewport and paints over the row) — size the CONTAINER instead.
#   - Cmd+T keeps Zen's centered floating search (zen.urlbar.replace-newtab
#     stays at Zen's default true): the float is a top-layer popover too and
#     centers itself once nothing pins the urlbar geometry — leave it alone.
#   - Compact mode position:fixes the toolbox off-screen (sidebar hover
#     reveal) = no UI at all in horizontal; neutralized in CSS until a real
#     auto-hide top bar exists. The compact toggle still sits in the toolbar
#     and currently no-ops visually.
#   - #zen-sidebar-top-buttons carries flex="1", mapped by xul.css to
#     flex:1 1 0% with UA-!important (unbeatable from author CSS) — it ate
#     half the row; _updateEvent removes the attribute, CSS caps first paint
#     with max-width:fit-content.
# Known polish: disabled back/forward render faint on fresh sessions.
# Interaction pass (2026-07-14, user reports):
#   - Window dragging: empty areas of both bar rows are -moz-window-dragging
#     drag regions (tabs/buttons/urlbar opt out) — nothing in Zen's vertical
#     layout made the horizontal rows draggable.
#   - "New Space" looked dead: the zen-workspace-creation pane is full-height
#     sidebar UI and rendered clipped above the window inside the 44px strip
#     (it also PRE-CREATES the space, so every attempt left a ghost). Floated
#     as a centered card; the host needs display:flex column +
#     height:fit-content or it collapses to a sliver. Cancel verified to
#     remove the pre-created space.
diff --git a/src/zen/common/modules/ZenStartup.mjs b/src/zen/common/modules/ZenStartup.mjs
index 307fa0d..9876e0f 100644
--- a/src/zen/common/modules/ZenStartup.mjs
+++ b/src/zen/common/modules/ZenStartup.mjs
@@ -94,7 +94,42 @@ class ZenStartup {
       this.closeWatermark();
       document
         .getElementById("tabbrowser-arrowscrollbox")
-        .setAttribute("orient", "vertical");
+        .setAttribute(
+          "orient",
+          // Kavacha: follow the tab-layout pref (patch 0010). This ran after
+          // the per-workspace orient fix and re-verticalized the startup
+          // space's strip, hiding exactly that space's tabs in horizontal.
+          Services.prefs.getBoolPref("zen.tabs.vertical", true)
+            ? "vertical"
+            : "horizontal"
+        );
+      if (!Services.prefs.getBoolPref("zen.tabs.vertical", true)) {
+        // Kavacha horizontal mode: macOS positions the native traffic
+        // lights on the buttonbox element — it must sit in the tab strip
+        // row (the top row), in normal flow.
+        const buttonBox = document.querySelector(
+          "#zen-sidebar-top-buttons .titlebar-buttonbox-container"
+        );
+        if (buttonBox) {
+          document.getElementById("TabsToolbar").prepend(buttonBox);
+        }
+        // Standard browser URL row: navigation buttons live LEFT of the
+        // URL bar, inside the nav bar itself.
+        const navTarget = document.getElementById(
+          "nav-bar-customization-target"
+        );
+        const urlbarContainer = document.getElementById("urlbar-container");
+        for (const id of [
+          "back-button",
+          "forward-button",
+          "stop-reload-button",
+        ]) {
+          const el = document.getElementById(id);
+          if (el && navTarget && urlbarContainer) {
+            navTarget.insertBefore(el, urlbarContainer);
+          }
+        }
+      }
       this.isReady = true;
       this.promiseInitializedResolve();
       delete this.promiseInitializedResolve;
