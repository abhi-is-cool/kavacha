+# file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+# Kavacha Component Marketplace (about:marketplace). The JS about-module is a
+# plain EXTRA_JS_MODULE (resource:///modules/KavachaAboutMarketplace.sys.mjs);
+# its components.conf registers the about: contract. The marketplace.html/css/js
+# chrome content is registered separately via jar.inc.mn (included from
+# src/browser/base/content/zen-assets.jar.inc.mn). ADR 0010.
+
+EXTRA_JS_MODULES += [
+    "KavachaAboutMarketplace.sys.mjs",
+]
+
+XPCOM_MANIFESTS += [
+    "components.conf",
+]
