+// Kavacha: curated per-workspace setting overrides (workspace.settings).
+// Deliberately an allowlist — workspaces sync across devices, so arbitrary
+// pref control would let a synced payload flip security-critical prefs.
+// `encode` maps the stored setting value to the pref value; `decode` maps the
+// current pref value to the checkbox state shown when no override exists.
+const KAVACHA_SPACE_SETTINGS = [
+  {
+    key: "colorScheme", // "light" | "dark"; absent = browser default
+    pref: "layout.css.prefers-color-scheme.content-override",
+    kind: "int",
+    menu: "radio",
+    encode: v => ({ dark: 0, light: 1 })[v],
+  },
+  {
+    key: "blockAutoplay", // true = block all media, false = block audible only
+    pref: "media.autoplay.default",
+    kind: "int",
+    menu: "checkbox",
+    l10n: "zen-workspaces-settings-block-autoplay",
+    encode: v => (v ? 5 /* BLOCKED_ALL */ : 1 /* BLOCKED (audible) */),
+    decode: prefValue => prefValue === 5,
+  },
+  {
+    key: "blockNotificationPrompts", // true = never ask for notifications
+    pref: "permissions.default.desktop-notification",
+    kind: "int",
+    menu: "checkbox",
+    l10n: "zen-workspaces-settings-block-notifications",
+    encode: v => (v ? 2 /* block */ : 0 /* ask */),
+    decode: prefValue => prefValue === 2,
+  },
+  {
+    key: "rememberPasswords",
+    pref: "signon.rememberSignons",
+    kind: "bool",
+    menu: "checkbox",
+    l10n: "zen-workspaces-settings-remember-passwords",
+    encode: v => !!v,
+    decode: prefValue => !!prefValue,
+  },
+  {
+    key: "searchSuggestions",
+    pref: "browser.search.suggest.enabled",
+    kind: "bool",
+    menu: "checkbox",
+    l10n: "zen-workspaces-settings-search-suggestions",
+    encode: v => !!v,
+    decode: prefValue => !!prefValue,
+  },
+];
