+
+/* == Kavacha welcome additions ============================================ */
+
+#kavacha-welcome-colors {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 14px;
+  align-items: center;
+  justify-content: center;
+  max-width: 320px;
+  margin: auto;
+}
+
+.kavacha-welcome-swatch {
+  width: 46px;
+  height: 46px;
+  min-width: 46px;
+  border-radius: 50%;
+  border: 2px solid transparent;
+  outline: 2px solid transparent;
+  outline-offset: 3px;
+  padding: 0;
+  cursor: pointer;
+  transition:
+    transform 120ms ease,
+    outline-color 120ms ease;
+}
+
+.kavacha-welcome-swatch:hover {
+  transform: scale(1.12);
+}
+
+.kavacha-welcome-swatch[selected] {
+  outline-color: light-dark(rgba(0, 0, 0, 0.6), rgba(255, 255, 255, 0.7));
+}
