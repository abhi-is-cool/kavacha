+// This Source Code Form is subject to the terms of the Mozilla Public
+// License, v. 2.0. If a copy of the MPL was not distributed with this
+// file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+// Kavacha "clear unpinned tabs on quit" (ROADMAP Phase 3 UX). Zen restores the
+// previous session on launch, which brings back EVERY tab. Kavacha's rule is
+// the opposite for casual tabs: when you quit, ordinary tabs should be gone and
+// only the tabs you deliberately PINNED should come back. Pinning is the
+// explicit "keep this" gesture.
+//
+// Mechanism: a process singleton that observes "quit-application-granted" — the
+// point at which quit is committed but windows are still alive and SessionStore
+// has not yet written its final state. We close every non-pinned tab in every
+// browser window. SessionStore keeps its in-memory state live as tabs close, so
+// the final write (at profile-before-change) already excludes them; pinned tabs
+// stay in the session and are restored next launch. Closed tabs land in the
+// normal "recently closed" list (undoable) but are not auto-restored.
+//
+// Gated on the pref kavacha.session.clear-unpinned-on-quit (default true) so it
+// can be turned off without a rebuild. skipPermitUnload avoids beforeunload
+// prompts blocking a quit the user already chose; closeWindowWithLastTab:false
+// keeps removeTab from tearing a window down mid-quit.
+
+const PREF = "kavacha.session.clear-unpinned-on-quit";
+
+export const KavachaSessionCleanup = {
+  _initialized: false,
+
+  /** Process-singleton init. Idempotent — safe to call once per window. */
+  init() {
+    if (this._initialized) {
+      return;
+    }
+    this._initialized = true;
+    Services.obs.addObserver(this, "quit-application-granted");
+  },
+
+  observe(subject, topic) {
+    if (topic !== "quit-application-granted") {
+      return;
+    }
+    // Fire once; nothing to observe after quit is granted.
+    Services.obs.removeObserver(this, "quit-application-granted");
+    if (!Services.prefs.getBoolPref(PREF, true)) {
+      return;
+    }
+    this._clearUnpinnedTabs();
+  },
+
+  _clearUnpinnedTabs() {
+    for (const win of Services.wm.getEnumerator("navigator:browser")) {
+      const gBrowser = win.gBrowser;
+      if (!gBrowser || win.closed) {
+        continue;
+      }
+      // Snapshot first: removeTab mutates gBrowser.tabs while we iterate.
+      const unpinned = Array.prototype.filter.call(
+        gBrowser.tabs,
+        tab => !tab.pinned && !tab.closing
+      );
+      for (const tab of unpinned) {
+        try {
+          gBrowser.removeTab(tab, {
+            animate: false,
+            skipPermitUnload: true,
+            closeWindowWithLastTab: false,
+          });
+        } catch (e) {
+          win.console?.error("KavachaSessionCleanup: removeTab failed", e);
+        }
+      }
+    }
+  },
+};
