+  // ==========================================================================
+  // Kavacha: per-workspace setting overrides (workspace.settings — curated
+  // keys only, see KAVACHA_SPACE_SETTINGS). Same baseline pattern as the
+  // search engine: the first override records the profile's value in
+  // kavacha.workspaces.settings-baseline, and spaces without that override
+  // restore it. Synchronous pref flips — no switch-latency cost.
+  // ==========================================================================
+  applyWorkspaceSettings(workspace) {
+    if (this.privateWindowOrDisabled || !workspace) {
+      return;
+    }
+    const BASELINE_PREF = "kavacha.workspaces.settings-baseline";
+    let baseline;
+    try {
+      baseline = JSON.parse(Services.prefs.getStringPref(BASELINE_PREF, "{}"));
+    } catch (e) {
+      baseline = {};
+    }
+    const overrides = workspace.settings || {};
+    for (const def of KAVACHA_SPACE_SETTINGS) {
+      const getPref = () =>
+        def.kind === "bool"
+          ? Services.prefs.getBoolPref(def.pref)
+          : Services.prefs.getIntPref(def.pref);
+      const setPref = value =>
+        def.kind === "bool"
+          ? Services.prefs.setBoolPref(def.pref, value)
+          : Services.prefs.setIntPref(def.pref, value);
+      if (Object.prototype.hasOwnProperty.call(overrides, def.key)) {
+        const value = def.encode(overrides[def.key]);
+        if (value === undefined) {
+          continue;
+        }
+        if (!(def.key in baseline)) {
+          baseline[def.key] = getPref();
+        }
+        if (getPref() !== value) {
+          setPref(value);
+        }
+      } else if (def.key in baseline) {
+        if (getPref() !== baseline[def.key]) {
+          setPref(baseline[def.key]);
+        }
+        delete baseline[def.key];
+      }
+    }
+    Services.prefs.setStringPref(BASELINE_PREF, JSON.stringify(baseline));
+  }
+
+  updateWorkspaceActionsMenuSettings(event) {
+    const workspace = this.#contextMenuData?.workspaceId
+      ? this.getWorkspaceFromId(this.#contextMenuData.workspaceId)
+      : this.getActiveWorkspaceFromCache();
+    const popup = event.target;
+    while (popup.firstChild) {
+      popup.firstChild.remove();
+    }
+    const overrides = workspace.settings || {};
+    // Website color scheme: Browser Default / Light / Dark radio group.
+    for (const [value, l10nId] of [
+      ["", "zen-workspaces-settings-color-default"],
+      ["light", "zen-workspaces-settings-color-light"],
+      ["dark", "zen-workspaces-settings-color-dark"],
+    ]) {
+      const item = document.createXULElement("menuitem");
+      item.setAttribute("type", "radio");
+      item.setAttribute("name", "kavacha-space-colorscheme");
+      item.setAttribute("closemenu", "none");
+      item.setAttribute("data-setting-key", "colorScheme");
+      item.setAttribute("data-setting-value", value);
+      document.l10n.setAttributes(item, l10nId);
+      if ((overrides.colorScheme || "") === value) {
+        item.setAttribute("checked", "true");
+      }
+      popup.appendChild(item);
+    }
+    popup.appendChild(document.createXULElement("menuseparator"));
+    for (const def of KAVACHA_SPACE_SETTINGS) {
+      if (def.menu !== "checkbox") {
+        continue;
+      }
+      const item = document.createXULElement("menuitem");
+      item.setAttribute("type", "checkbox");
+      item.setAttribute("closemenu", "none");
+      item.setAttribute("data-setting-key", def.key);
+      document.l10n.setAttributes(item, def.l10n);
+      // Show the override if set, otherwise the current effective pref value.
+      const checked = Object.prototype.hasOwnProperty.call(overrides, def.key)
+        ? !!overrides[def.key]
+        : def.decode(
+            def.kind === "bool"
+              ? Services.prefs.getBoolPref(def.pref)
+              : Services.prefs.getIntPref(def.pref)
+          );
+      if (checked) {
+        item.setAttribute("checked", "true");
+      }
+      popup.appendChild(item);
+    }
+    popup.appendChild(document.createXULElement("menuseparator"));
+    const resetItem = document.createXULElement("menuitem");
+    resetItem.setAttribute("data-setting-reset", "true");
+    document.l10n.setAttributes(resetItem, "zen-workspaces-settings-reset");
+    popup.appendChild(resetItem);
+  }
+
+  async contextChangeSettings(event) {
+    const workspace = this.getWorkspaces().find(
+      w =>
+        w.uuid === (this.#contextMenuData?.workspaceId || this.activeWorkspace)
+    );
+    if (!workspace) {
+      return;
+    }
+    const target = event.target;
+    if (target.hasAttribute("data-setting-reset")) {
+      delete workspace.settings;
+    } else {
+      const key = target.getAttribute("data-setting-key");
+      const def = KAVACHA_SPACE_SETTINGS.find(d => d.key === key);
+      if (!def) {
+        return;
+      }
+      workspace.settings = workspace.settings || {};
+      if (def.menu === "radio") {
+        const value = target.getAttribute("data-setting-value");
+        if (value) {
+          workspace.settings[key] = value;
+        } else {
+          delete workspace.settings[key];
+        }
+      } else {
+        // Checkbox menuitems autotoggle before command fires, so the current
+        // checked state is the newly-desired value.
+        workspace.settings[key] = target.getAttribute("checked") === "true";
+      }
+      if (!Object.keys(workspace.settings).length) {
+        delete workspace.settings;
+      }
+    }
+    this.saveWorkspace(workspace);
+    if (this.isWorkspaceActive(workspace)) {
+      this.applyWorkspaceSettings(workspace);
+    }
+  }
