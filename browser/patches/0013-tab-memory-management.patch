@@ -135,6 +135,11 @@ class ZenStartup {
       ChromeUtils.importESModule(
         "resource:///modules/KavachaNewTab.sys.mjs"
       ).KavachaNewTab.init();
+      // Kavacha: discard long-inactive background tabs to free memory
