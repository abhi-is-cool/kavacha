@@ -3617,6 +3658,83 @@ class nsZenWorkspaces {
     this.#notesFile.saveSoon();
   }
 
+  // ==========================================================================
+  // Kavacha: workspace archiving (PLATFORM_PLAN.md — workspaces as persistent
+  // projects). Archived spaces keep all their data (tabs, notes, identity) and
+  // stay in the session store and sync; they are simply hidden from the strip,
+  // icon row and navigation, and their tabs are unloaded to free memory.
+  // Restore from the "Archived Spaces" submenu at any time.
+  // ==========================================================================
+  async archiveWorkspace(workspaceId = null) {
+    const uuid = workspaceId || this.activeWorkspace;
+    const workspace = this.getWorkspaceFromId(uuid);
+    const visible = this.getWorkspaces().filter(w => !w.archived);
+    if (!workspace || workspace.archived || visible.length <= 1) {
+      return;
+    }
+    if (this.isWorkspaceActive(workspace)) {
+      const next = visible.find(w => w.uuid !== workspace.uuid);
+      await this.changeWorkspace(next);
+    }
+    workspace.archived = true;
+    this.saveWorkspace(workspace);
+    const tabsToUnload = this.allStoredTabs.filter(
+      tab =>
+        tab.getAttribute("zen-workspace-id") === workspace.uuid &&
+        !tab.hasAttribute("zen-empty-tab") &&
+        !tab.hasAttribute("zen-essential") &&
+        !tab.hasAttribute("pending")
+    );
+    if (tabsToUnload.length) {
+      await gBrowser.explicitUnloadTabs(tabsToUnload);
+    }
+    this.#applyArchivedStateToElements();
+    this.#fireSpaceUIUpdate();
+  }
+
+  async unarchiveWorkspace(workspaceId) {
+    const workspace = this.getWorkspaceFromId(workspaceId);
+    if (!workspace?.archived) {
+      return;
+    }
+    delete workspace.archived;
+    this.saveWorkspace(workspace);
+    this.#applyArchivedStateToElements();
+    this.#fireSpaceUIUpdate();
+    await this.changeWorkspace(workspace);
+  }
+
+  #applyArchivedStateToElements() {
+    for (const workspace of this.getWorkspaces()) {
+      const element = this.workspaceElement(workspace.uuid);
+      if (element) {
+        element.hidden = !!workspace.archived;
+      }
+    }
+  }
+
+  updateArchivedWorkspacesMenu(event) {
+    const popup = event.target;
+    while (popup.firstChild) {
+      popup.firstChild.remove();
+    }
+    for (const workspace of this.getWorkspaces().filter(w => w.archived)) {
+      const item = document.createXULElement("menuitem");
+      item.setAttribute("zen-workspace-id", workspace.uuid);
+      const iconIsSvg = workspace.icon && workspace.icon.endsWith(".svg");
+      let name = workspace.name;
+      if (workspace.icon && !iconIsSvg) {
+        name = `${workspace.icon}  ${name}`;
+      }
+      item.setAttribute("label", name);
+      if (iconIsSvg) {
+        item.setAttribute("image", workspace.icon);
+        item.classList.add("menuitem-iconic");
+      }
+      popup.appendChild(item);
+    }
+  }
+
   async closeAllUnpinnedTabs() {
     const workspaceId =
       this.#contextMenuData?.workspaceId || this.activeWorkspace;
@@ -3667,8 +3785,8 @@ class nsZenWorkspaces {
     whileScrolling = false,
     disableWrap = false
   ) {
-    // Cycle through workspaces
-    let workspaces = this.getWorkspaces();
+    // Cycle through workspaces (Kavacha: archived spaces are not stops)
+    let workspaces = this.getWorkspaces().filter(w => !w.archived);
     let activeWorkspace = this.getActiveWorkspace();
     let workspaceIndex = workspaces.indexOf(activeWorkspace);
 
