       return;
     }
 
@@ -244,6 +247,27 @@
         win.console?.error("KavachaThemeEngine: failed to load style.css", e);
       }
     }
+
+    this._applyColorScheme(win, root);
+  },
+
+  // Align the chrome color-scheme to the ACTIVE surface's luminance so native
+  // toolbar/tab text and icons resolve readable on any theme — dark themes and
+  // bright custom surfaces (about:studio) alike. Read the *computed*
+  // --kavacha-surface so we react to whatever set it (this engine, the 0016
+  // floor, or a live about:studio edit), not just this engine's own writes.
+  _applyColorScheme(win, root) {
+    const raw = win
+      .getComputedStyle(root)
+      .getPropertyValue("--kavacha-surface")
+      .trim();
+    const rgb = parseCssColor(raw);
+    if (!rgb) {
+      return;
+    }
+    const luminance =
+      (0.2126 * rgb[0] + 0.7152 * rgb[1] + 0.0722 * rgb[2]) / 255;
+    root.style.colorScheme = luminance < 0.45 ? "dark" : "light";
   },
 };
 
@@ -252,3 +276,32 @@
 function colorsFileOf(manifest) {
   return typeof manifest.colors === "string" ? manifest.colors : "colors.json";
 }
+
+// Parse a #rgb / #rrggbb / rgb()/rgba() color string to [r, g, b] (0..255), or
+// null if it isn't one of those forms.
+function parseCssColor(str) {
+  if (!str) {
+    return null;
+  }
+  const s = str.trim();
+  let m = s.match(/^#([0-9a-f]{3})$/i);
+  if (m) {
+    return m[1].split("").map(c => parseInt(c + c, 16));
+  }
+  m = s.match(/^#([0-9a-f]{6})$/i);
+  if (m) {
+    return [0, 2, 4].map(i => parseInt(m[1].slice(i, i + 2), 16));
+  }
+  m = s.match(/^rgba?\(([^)]+)\)$/i);
+  if (m) {
+    const parts = m[1]
+      .split(/[,\s/]+/)
+      .filter(Boolean)
+      .slice(0, 3)
+      .map(Number);
+    if (parts.length === 3 && parts.every(n => !Number.isNaN(n))) {
+      return parts;
+    }
+  }
+  return null;
+}
