+  // ==========================================================================
+  // Kavacha: workspace notes (PLATFORM_PLAN.md MVP item). Notes live in a
+  // profile-local JSONFile (kavacha-notes.json), keyed by workspace uuid —
+  // deliberately NOT on the space object: they'd bloat the session file and
+  // ride Mozilla-account sync. They stay on this device until Kavacha's own
+  // E2E sync (Phase 5) can carry them. Last-write-wins across windows.
+  // ==========================================================================
+  #notesFile = null;
+  #notesSaveTimer = null;
+
+  async #ensureNotesFile() {
+    if (!this.#notesFile) {
+      this.#notesFile = new lazy.JSONFile({
+        path: PathUtils.join(PathUtils.profileDir, "kavacha-notes.json"),
+      });
+      await this.#notesFile.load();
+      this.#notesFile.data.notes ||= {};
+    }
+    return this.#notesFile;
+  }
+
+  async openWorkspaceNotes(workspaceId = null) {
+    if (this.privateWindowOrDisabled) {
+      return;
+    }
+    const workspace = workspaceId
+      ? this.getWorkspaceFromId(workspaceId)
+      : this.getActiveWorkspaceFromCache();
+    if (!workspace) {
+      return;
+    }
+    const file = await this.#ensureNotesFile();
+    const panel = document.getElementById("kavacha-notes-panel");
+    const textarea = document.getElementById("kavacha-notes-textarea");
+    document.l10n.setAttributes(
+      document.getElementById("kavacha-notes-title"),
+      "kavacha-notes-title",
+      { name: workspace.name }
+    );
+    panel.setAttribute("data-workspace-id", workspace.uuid);
+    textarea.value = file.data.notes[workspace.uuid]?.content ?? "";
+    const anchor = this.workspaceIcons || gURLBar.textbox;
+    panel.openPopup(anchor, "after_start", 0, 0, false, false);
+    textarea.focus();
+  }
+
+  #flushWorkspaceNotes() {
+    const panel = document.getElementById("kavacha-notes-panel");
+    const uuid = panel.getAttribute("data-workspace-id");
+    if (!uuid || !this.#notesFile) {
+      return;
+    }
+    const content = document.getElementById("kavacha-notes-textarea").value;
+    if (content.trim()) {
+      this.#notesFile.data.notes[uuid] = {
+        content,
+        updatedAt: new Date().toISOString(),
+      };
+    } else {
+      delete this.#notesFile.data.notes[uuid];
+    }
+    this.#notesFile.saveSoon();
+  }
