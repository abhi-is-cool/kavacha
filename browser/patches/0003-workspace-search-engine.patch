+  // ==========================================================================
+  // Kavacha: per-workspace search engine (workspace.searchProvider = engine
+  // name; absent = browser default). The pref below remembers the profile's
+  // baseline default so we can restore it on spaces without an override.
+  // ==========================================================================
+  #applyingWorkspaceSearchEngine = false;
+
+  async applyWorkspaceSearchEngine(workspace) {
+    if (this.privateWindowOrDisabled || !workspace) {
+      return;
+    }
+    await Services.search.promiseInitialized;
+    const baselinePref = "kavacha.workspaces.baseline-search-engine";
+    const override = workspace.searchProvider;
+    try {
+      this.#applyingWorkspaceSearchEngine = true;
+      if (override) {
+        const engine = Services.search.getEngineByName(override);
+        if (!engine || engine.hidden) {
+          // Engine not installed on this device (e.g. synced from another
+          // machine) — leave the default alone rather than failing.
+          return;
+        }
+        if (Services.search.defaultEngine?.name !== override) {
+          if (!Services.prefs.prefHasUserValue(baselinePref)) {
+            Services.prefs.setStringPref(
+              baselinePref,
+              Services.search.defaultEngine?.name || ""
+            );
+          }
+          await Services.search.setDefault(
+            engine,
+            Services.search.CHANGE_REASON.USER
+          );
+        }
+      } else if (Services.prefs.prefHasUserValue(baselinePref)) {
+        const baselineName = Services.prefs.getStringPref(baselinePref);
+        Services.prefs.clearUserPref(baselinePref);
+        const engine =
+          baselineName && Services.search.getEngineByName(baselineName);
+        if (
+          engine &&
+          !engine.hidden &&
+          Services.search.defaultEngine?.name !== baselineName
+        ) {
+          await Services.search.setDefault(
+            engine,
+            Services.search.CHANGE_REASON.USER
+          );
+        }
+      }
+    } finally {
+      this.#applyingWorkspaceSearchEngine = false;
+    }
+  }
+
+  // The user changed the default engine themselves (prefs UI, searchbar…)
+  // while a workspace override is active: adopt it as the workspace's engine
+  // so we don't silently revert their choice on the next space switch.
+  onDefaultSearchEngineChanged() {
+    if (this.#applyingWorkspaceSearchEngine || this.privateWindowOrDisabled) {
+      return;
+    }
+    const workspace = this.getActiveWorkspaceFromCache();
+    if (!workspace?.searchProvider) {
+      return;
+    }
+    const newName = Services.search.defaultEngine?.name;
+    if (newName && workspace.searchProvider !== newName) {
+      workspace.searchProvider = newName;
+      this.saveWorkspace(workspace);
+    }
+  }
+
+  updateWorkspaceActionsMenuSearchEngine(event) {
+    const workspace = this.#contextMenuData?.workspaceId
+      ? this.getWorkspaceFromId(this.#contextMenuData.workspaceId)
+      : this.getActiveWorkspaceFromCache();
+    const popup = event.target;
+    while (popup.firstChild) {
+      popup.firstChild.remove();
+    }
+    const defaultItem = document.createXULElement("menuitem");
+    defaultItem.setAttribute("type", "radio");
+    document.l10n.setAttributes(
+      defaultItem,
+      "zen-workspaces-search-engine-default"
+    );
+    if (!workspace.searchProvider) {
+      defaultItem.setAttribute("checked", "true");
+    }
+    popup.appendChild(defaultItem);
+    popup.appendChild(document.createXULElement("menuseparator"));
+    Services.search.getVisibleEngines().then(engines => {
+      for (const engine of engines) {
+        const item = document.createXULElement("menuitem");
+        item.setAttribute("type", "radio");
+        item.setAttribute("label", engine.name);
+        item.setAttribute("data-search-engine-name", engine.name);
+        if (engine.iconURI?.spec) {
+          item.setAttribute("image", engine.iconURI.spec);
+          item.classList.add("menuitem-iconic");
+        }
+        if (workspace.searchProvider === engine.name) {
+          item.setAttribute("checked", "true");
+        }
+        popup.appendChild(item);
+      }
+    });
+  }
+
+  async contextChangeSearchEngine(event) {
+    const workspace = this.getWorkspaces().find(
+      w =>
+        w.uuid === (this.#contextMenuData?.workspaceId || this.activeWorkspace)
+    );
+    if (!workspace) {
+      return;
+    }
+    const engineName = event.target.getAttribute("data-search-engine-name");
+    if (engineName) {
+      workspace.searchProvider = engineName;
+    } else {
+      delete workspace.searchProvider;
+    }
+    this.saveWorkspace(workspace);
+    if (this.isWorkspaceActive(workspace)) {
+      await this.applyWorkspaceSearchEngine(workspace);
+    }
+  }
+
   async closeAllUnpinnedTabs() {
     const workspaceId =
       this.#contextMenuData?.workspaceId || this.activeWorkspace;
