index 0000000..f0e0068
--- /dev/null
+++ b/src/zen/common/styles/kavacha-menu.inc.css
@@ -0,0 +1,82 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/* ==========================================================================
+   Kavacha menu button + registry-driven panel (patch 0030). Styles the gear
+   button in the top-right cluster (#kavacha-menu-button) and the panel it
+   opens (#kavacha-menu-panel). %include'd from zen-theme.css after the other
+   Kavacha layers.
+
+   Colors use the --kavacha-* surface tokens (patch 0016 bakes the Midnight
+   floor; the theme engine, patch 0023, re-tints them live) with plain
+   fallbacks, so the panel follows the active theme. The XUL panel chrome is
+   themed by pointing --panel-background / --panel-border-color at those tokens.
+   ========================================================================== */
+
+/* --- The toolbar button: gear icon --------------------------------------- */
+#kavacha-menu-button {
+  list-style-image: url("chrome://browser/skin/zen-icons/settings.svg");
+}
+
+/* --- The panel ----------------------------------------------------------- */
+#kavacha-menu-panel {
+  --panel-background: var(--kavacha-surface-elevated, #1d1930);
+  --panel-border-color: var(--kavacha-border, #2e2846);
+  --panel-color: var(--kavacha-text-primary, #edeaf7);
+  min-width: 280px;
+  padding: 6px;
+}
+
+/* Small, dim, uppercase domain headers. */
+.kavacha-menu-header {
+  margin: 8px 10px 2px;
+  font-size: 11px;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+  color: var(--kavacha-text-secondary, #a79fc4);
+}
+
+.kavacha-menu-header:first-child {
+  margin-top: 2px;
+}
+
+/* Rows: icon + label, full-width, subtle theme-aware hover. */
+.kavacha-menu-item {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  width: 100%;
+  margin: 0;
+  padding: 8px 10px;
+  border-radius: 8px;
+  color: var(--kavacha-text-primary, #edeaf7);
+  background: transparent;
+  -moz-box-align: center;
+}
+
+.kavacha-menu-item > .toolbarbutton-icon {
+  width: 16px;
+  height: 16px;
+  margin-inline-end: 0;
+}
+
+.kavacha-menu-item > .toolbarbutton-text {
+  text-align: start;
+}
+
+.kavacha-menu-item:hover,
+.kavacha-menu-item:focus {
+  background-color: var(
+    --kavacha-tab-hover-background,
+    color-mix(in srgb, currentColor 10%, transparent)
+  );
+}
+
+.kavacha-menu-item:active {
+  background-color: var(
+    --kavacha-tab-active-background,
+    color-mix(in srgb, currentColor 16%, transparent)
+  );
+}
