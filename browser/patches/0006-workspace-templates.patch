+  // ==========================================================================
+  // Kavacha: workspace templates (KAVACHA_SPACE_TEMPLATES). Creates a space
+  // with its own dedicated container plus the template's theme, search engine
+  // and settings — a complete identity in one click. Everything downstream
+  // (applying engine/settings on switch) is handled by the existing hooks.
+  // ==========================================================================
+  async createWorkspaceFromTemplate(templateId) {
+    const template = KAVACHA_SPACE_TEMPLATES.find(t => t.id === templateId);
+    if (!template || this.privateWindowOrDisabled) {
+      return null;
+    }
+    // Reuse a same-named container if one exists (e.g. template re-created
+    // after deleting the space) — containers are cheap but duplicates confuse.
+    let containerTabId = 0;
+    try {
+      const existing = ContextualIdentityService.getPublicIdentities().find(
+        identity => identity.name === template.container.name
+      );
+      const identity =
+        existing ||
+        ContextualIdentityService.create(
+          template.container.name,
+          template.container.icon,
+          template.container.color
+        );
+      containerTabId = identity.userContextId;
+    } catch (e) {
+      console.error("gZenWorkspaces: could not create template container", e);
+    }
+    return this.createAndSaveWorkspace(
+      template.name,
+      gZenEmojiPicker.getSVGURL(template.svgIcon),
+      false,
+      containerTabId,
+      {
+        beforeChangeCallback: async workspace => {
+          workspace.theme = nsZenThemePicker.getTheme(
+            [
+              {
+                c: template.themeColor,
+                isPrimary: true,
+                isCustom: false,
+                lightness: 50,
+                type: "explicit-lightness",
+              },
+            ],
+            0.5,
+            0
+          );
+          if (template.searchProvider) {
+            workspace.searchProvider = template.searchProvider;
+          }
+          if (template.settings) {
+            workspace.settings = { ...template.settings };
+          }
+          workspace.template = template.id;
+          this.saveWorkspace(workspace);
+        },
+      }
+    );
+  }
