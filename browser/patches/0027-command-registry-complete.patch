+    },
   };
 }
 
 export const globalActions = globalActionsTemplate.map(wrapAction);
 
 // Runtime registrations (late features, plugins) land in the live palette.
 KavachaCommandRegistry.onRegister(command => {
   globalActions.push(wrapAction(command));
 });
+
+// ...and runtime unregistrations (plugin disable, marketplace uninstall) leave
+// it, so a revoked command stops appearing in the palette immediately.
+KavachaCommandRegistry.onUnregister(command => {
+  const i = globalActions.findIndex(a => a.l10nId === command.l10nId);
+  if (i >= 0) {
+    globalActions.splice(i, 1);
+  }
+});
