+  // ==========================================================================
+  // Kavacha: per-workspace extension set (workspace.extensions = array of
+  // addon IDs active in this space; absent = all extensions, Zen behavior).
+  //
+  // Firefox has no per-container extension scoping, so this toggles addons
+  // globally at switch time. A tracking pref records which addons *Kavacha*
+  // disabled, so a space without a list only re-enables those — a user's own
+  // global disables are never overridden. This is the ADR 0003 prototype;
+  // switch timing is logged (zen.workspaces.debug) for the go/no-go call.
+  // ==========================================================================
+  #extensionApplyChain = Promise.resolve();
+
+  applyWorkspaceExtensions(workspace) {
+    if (this.privateWindowOrDisabled || !workspace) {
+      return this.#extensionApplyChain;
+    }
+    this.#extensionApplyChain = this.#extensionApplyChain
+      .then(() => this.#doApplyWorkspaceExtensions(workspace))
+      .catch(e =>
+        console.error("gZenWorkspaces: error applying workspace extensions", e)
+      );
+    return this.#extensionApplyChain;
+  }
+
+  async #doApplyWorkspaceExtensions(workspace) {
+    const TRACK_PREF = "kavacha.workspaces.extensions-disabled";
+    const list = workspace.extensions;
+    const start = performance.now();
+    const addons = (
+      await lazy.AddonManager.getAddonsByTypes(["extension"])
+    ).filter(a => !a.isSystem && !a.isBuiltin && !a.hidden);
+    let tracked;
+    try {
+      tracked = new Set(
+        JSON.parse(Services.prefs.getStringPref(TRACK_PREF, "[]"))
+      );
+    } catch (e) {
+      tracked = new Set();
+    }
+    const ops = [];
+    if (Array.isArray(list)) {
+      const wanted = new Set(list);
+      for (const addon of addons) {
+        if (wanted.has(addon.id)) {
+          // Only re-enable addons Kavacha disabled — a global user disable
+          // (not in the tracking pref) is the user's choice, keep it.
+          if (addon.userDisabled && tracked.has(addon.id)) {
+            ops.push(addon.enable());
+            tracked.delete(addon.id);
+          }
+        } else if (!addon.userDisabled) {
+          ops.push(addon.disable());
+          tracked.add(addon.id);
+        }
+      }
+    } else {
+      for (const addon of addons) {
+        if (addon.userDisabled && tracked.has(addon.id)) {
+          ops.push(addon.enable());
+          tracked.delete(addon.id);
+        }
+      }
+    }
+    Services.prefs.setStringPref(TRACK_PREF, JSON.stringify([...tracked]));
+    await Promise.all(ops);
+    if (ops.length) {
+      this.log(
+        `workspace extensions applied: ${ops.length} toggles in ${Math.round(
+          performance.now() - start
+        )}ms`
+      );
+    }
+  }
+
+  updateWorkspaceActionsMenuExtensions(event) {
+    const workspace = this.#contextMenuData?.workspaceId
+      ? this.getWorkspaceFromId(this.#contextMenuData.workspaceId)
+      : this.getActiveWorkspaceFromCache();
