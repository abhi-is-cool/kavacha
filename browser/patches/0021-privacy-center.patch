+
+/* Kavacha Privacy Center */
+#kavachaPrivacyCards {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
+  gap: 12px;
+  margin-block: 16px 20px;
+}
+
+.kavacha-privacy-card {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+  padding: 14px 16px;
+  border: 1px solid var(--zen-colors-border);
+  border-radius: 8px;
+  background: var(--zen-colors-tertiary);
+}
+
+.kavacha-privacy-card-value {
+  font-size: 1.7em;
+  font-weight: 600;
+}
+
+.kavacha-privacy-card-caption {
+  opacity: 0.7;
+  font-size: 0.95em;
+}
+
+.kavacha-privacy-row {
+  justify-content: space-between;
+  padding-block: 7px;
+  border-bottom: 1px solid var(--zen-colors-border);
+}
+
+.kavacha-privacy-row:last-child {
+  border-bottom: none;
+}
+
