+    get label() {
+      // Runtime commands (marketplace components, plugins) can't add .ftl
+      // keys, so they pass a literal `rawLabel`; built-ins localize by l10nId.
+      return action.rawLabel ?? lazy.l10n.formatValueSync(action.l10nId);
+    },
+    // Kavacha commands carry a `domain`; expose its localized label so a
+    // grouped palette renderer can show section headers. Undefined (harmless)
