+
+// Kavacha command registry (ROADMAP Phase 3; PLATFORM_PLAN.md § "Command
+// registry"). Every Kavacha feature exposes itself here as a Cmd+K command,
+// organized by domain, and it is the surface plugins will extend.
+//
+// The palette (ZenUBGlobalActions) spreads all() into its action list at
+// import and binds a live sink so register() calls made at runtime — by
+// late-initializing features or future plugins — appear immediately.
+//
+// A command is: { l10nId, command(window)|"commandId", icon, domain,
+// isAvailable?(window) }. Domain is metadata (grouped display is a later
+// palette enhancement); the l10nId keys browser/zen-command-palette.ftl.
+
+export const KavachaCommandDomain = {
+  NAVIGATION: "navigation",
+  ORGANIZATION: "organization",
+  PRODUCTIVITY: "productivity",
+  APPEARANCE: "appearance",
+};
+
+const kNotPrivate = window => !window.gZenWorkspaces?.privateWindowOrDisabled;
+const kHasBackgroundSpaces = window =>
+  kNotPrivate(window) &&
+  window.gZenWorkspaces?.getWorkspaces?.().filter(w => !w.archived).length > 1;
+
+// Built-in Kavacha commands. Ordered by domain for readability; the palette
+// fuzzy-matches by label so on-screen order comes from match score.
+const BUILTIN = [
+  // -- Navigation ----------------------------------------------------------
+  {
+    l10nId: "kavacha-action-universal-search",
+    command: window => window.gKavachaUniversalSearch.open(),
+    icon: "chrome://browser/skin/zen-icons/search-glass.svg",
+    domain: KavachaCommandDomain.NAVIGATION,
+  },
+
+  // -- Organization --------------------------------------------------------
+  {
+    l10nId: "kavacha-action-new-space-student",
+    command: window =>
+      window.gZenWorkspaces.createWorkspaceFromTemplate("student"),
+    icon: "chrome://browser/skin/zen-icons/selectable/school.svg",
+    domain: KavachaCommandDomain.ORGANIZATION,
+    isAvailable: kNotPrivate,
+  },
+  {
+    l10nId: "kavacha-action-new-space-developer",
+    command: window =>
+      window.gZenWorkspaces.createWorkspaceFromTemplate("developer"),
+    icon: "chrome://browser/skin/zen-icons/selectable/code.svg",
+    domain: KavachaCommandDomain.ORGANIZATION,
+    isAvailable: kNotPrivate,
+  },
+  {
+    l10nId: "kavacha-action-new-space-privacy",
+    command: window =>
+      window.gZenWorkspaces.createWorkspaceFromTemplate("privacy"),
+    icon: "chrome://browser/skin/zen-icons/selectable/lock-closed.svg",
+    domain: KavachaCommandDomain.ORGANIZATION,
+    isAvailable: kNotPrivate,
+  },
+  {
+    l10nId: "kavacha-action-archive-space",
+    command: window => window.gZenWorkspaces.archiveWorkspace(),
+    icon: "chrome://browser/skin/zen-icons/selectable/inbox.svg",
+    domain: KavachaCommandDomain.ORGANIZATION,
+    isAvailable: kHasBackgroundSpaces,
+  },
+
+  // -- Productivity --------------------------------------------------------
+  {
+    l10nId: "kavacha-action-workspace-notes",
+    command: window => window.gZenWorkspaces.openWorkspaceNotes(),
+    icon: "chrome://browser/skin/zen-icons/selectable/page.svg",
+    domain: KavachaCommandDomain.PRODUCTIVITY,
+    isAvailable: kNotPrivate,
+  },
+  {
+    l10nId: "kavacha-action-sleep-tabs",
+    command: () =>
+      ChromeUtils.importESModule(
+        "resource:///modules/KavachaTabMemory.sys.mjs"
+      ).KavachaTabMemory.sleepBackgroundTabsNow(),
+    icon: "chrome://browser/skin/zen-icons/selectable/clock.svg",
+    domain: KavachaCommandDomain.PRODUCTIVITY,
+  },
+
+  // -- Appearance ----------------------------------------------------------
+  {
+    l10nId: "kavacha-action-toggle-newtab",
+    // Flip between the floating search and the Kavacha dashboard; KavachaNewTab
+    // observes the pref and re-points about:newtab live.
+    command: () => {
+      const on = Services.prefs.getBoolPref("zen.urlbar.replace-newtab", true);
+      Services.prefs.setBoolPref("zen.urlbar.replace-newtab", !on);
+    },
+    icon: "chrome://browser/skin/zen-icons/selectable/window.svg",
+    domain: KavachaCommandDomain.APPEARANCE,
+  },
+];
+
+const _registered = [];
+const _sinks = [];
+
+export const KavachaCommandRegistry = {
+  domains: KavachaCommandDomain,
+
+  /**
+   * Register a command at runtime (late features, plugins). Returns an
+   * unregister function. Live palettes pick it up via the bound sink.
+   */
+  register(command) {
+    _registered.push(command);
+    for (const sink of _sinks) {
+      sink(command);
+    }
+    return () => {
+      const i = _registered.indexOf(command);
+      if (i >= 0) {
+        _registered.splice(i, 1);
+      }
+    };
+  },
+
+  /** All commands, built-ins first, in registration order. */
+  all() {
+    return [...BUILTIN, ..._registered];
+  },
+
+  /** ZenUBGlobalActions binds a sink so runtime registrations reach it. */
+  onRegister(sink) {
+    _sinks.push(sink);
+  },
+};
