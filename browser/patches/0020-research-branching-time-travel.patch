diff --git a/src/zen/spaces/ZenSpaceManager.mjs b/src/zen/spaces/ZenSpaceManager.mjs
index 136c5f5..3eb56d2 100644
--- a/src/zen/spaces/ZenSpaceManager.mjs
+++ b/src/zen/spaces/ZenSpaceManager.mjs
@@ -3671,6 +3671,192 @@ class nsZenWorkspaces {
     return file.data.notes;
   }
 
+  // Branching copies the parent's note into the child through the same
+  // single-owner file (ADR 0006: the note is part of the line of thought).
+  async kavachaSetNote(uuid, content) {
+    const file = await this.#ensureNotesFile();
+    if (content?.trim()) {
+      file.data.notes[uuid] = {
+        content,
+        updatedAt: new Date().toISOString(),
+      };
+    } else {
+      delete file.data.notes[uuid];
+    }
+    file.saveSoon();
+  }
+
+  // ==========================================================================
+  // Kavacha: research branching (ROADMAP Phase 2.5; consumes ADR 0006).
+  // Fork a space into a named alternative path: snapshot it (or start from a
+  // given snapshot id), create a child space carrying parent metadata, and
+  // rebuild the snapshot's tabs in it from their SessionStore state.
+  // ==========================================================================
+  async kavachaBranchSpace(snapshotId = null) {
+    if (this.privateWindowOrDisabled) {
+      return null;
+    }
+    const { KavachaSpaceHistory } = ChromeUtils.importESModule(
+      "resource:///modules/KavachaSpaceHistory.sys.mjs"
+    );
+    let snapshot = null;
+    if (snapshotId == null) {
+      const uuid = this.activeWorkspace;
+      // Snapshot the branch point; dedup returning null means the latest
+      // stored snapshot already IS the current state — use it.
+      const newId = await KavachaSpaceHistory.snapshotSpace(
+        window,
+        uuid,
+        "branch"
+      );
+      const id =
+        newId ?? (await KavachaSpaceHistory.listSnapshots(uuid))[0]?.id;
+      snapshot = id != null ? await KavachaSpaceHistory.getSnapshot(id) : null;
+    } else {
+      snapshot = await KavachaSpaceHistory.getSnapshot(snapshotId);
+    }
+    if (!snapshot) {
+      return null;
+    }
+    const payload = snapshot.payload;
+    const parent = this.getWorkspaceFromId(snapshot.spaceUuid);
+    const branchName = `${payload.spaceName || parent?.name || "Space"} / branch`;
+    const workspace = await this.createAndSaveWorkspace(
+      branchName,
+      payload.spaceIcon || parent?.icon,
+      false,
+      payload.containerTabId ?? 0,
+      {
+        beforeChangeCallback: async workspaceData => {
+          workspaceData.parentSpaceId = snapshot.spaceUuid;
+          workspaceData.branchedFromSnapshotId = snapshot.id;
+          workspaceData.branchedAt = Date.now();
+        },
+      }
+    );
+    if (!workspace) {
+      return null;
+    }
+    // The branch's strip element materializes asynchronously after the
+    // switch; moveTabsToWorkspace silently skips tabs when the target
+    // container doesn't exist yet — wait for it (worst case ~3s).
+    for (
+      let i = 0;
+      i < 60 && !this.workspaceElement(workspace.uuid)?.tabsContainer;
+      i++
+    ) {
+      await new Promise(resolve => setTimeout(resolve, 50));
+    }
+    // Rebuild the snapshot's tabs in the branch (now the active space) as
+    // LAZY tabs: real URL up front (readable strip, no blank-tab dedup),
+    // full captured state seeded through TabStateCache so activation
+    // restores scroll/form/history — the same mechanism Zen's welcome uses
+    // for its preset tabs. Pinned fidelity is a follow-up: everything
+    // restores as a normal tab.
+    const { TabStateCache } = ChromeUtils.importESModule(
+      "resource:///modules/sessionstore/TabStateCache.sys.mjs"
+    );
+    for (const t of payload.tabs) {
+      try {
+        const tab = gBrowser.addTrustedTab(t.url || "about:blank", {
+          createLazyBrowser: true,
+          inBackground: true,
+        });
+        // New tabs land in the ACTIVE space's container already, which makes
+        // moveTabsToWorkspace early-continue before it ever sets the
+        // attribute — set it explicitly or the tab is invisible to every
+        // workspace filter.
+        tab.setAttribute("zen-workspace-id", workspace.uuid);
+        // TabStateCache holds per-datum fields (history nested), not
+        // getTabState's flat JSON — reshape or activation restores blank.
+        const st = JSON.parse(t.state);
+        const cached = {
+          history: { entries: st.entries, index: st.index },
+        };
+        if (st.scroll) {
+          cached.scroll = st.scroll;
+        }
+        if (st.formdata) {
+          cached.formdata = st.formdata;
+        }
+        if (st.image) {
+          cached.image = st.image;
+        }
+        TabStateCache.update(tab.linkedBrowser.permanentKey, cached);
+        this.moveTabToWorkspace(tab, workspace.uuid);
+      } catch (e) {
+        console.error("kavachaBranchSpace: tab restore failed", e);
+      }
+    }
+    if (payload.note) {
+      await this.kavachaSetNote(workspace.uuid, payload.note);
+    }
+    gZenUIManager.updateTabsToolbar();
+    return workspace;
+  }
+
+  // ==========================================================================
+  // Kavacha: time-travel timeline (ROADMAP Phase 2.5; consumes ADR 0006).
+  // Browse the active space's snapshots and restore any of them — restore is
+  // deliberately NON-destructive: it forks the snapshot as a branch
+  // (kavachaBranchSpace), so the current line of work is never overwritten.
+  // Step-through replay is a follow-up.
+  // ==========================================================================
+  async kavachaOpenSpaceTimeline() {
+    if (this.privateWindowOrDisabled) {
+      return;
+    }
+    const workspace = this.getActiveWorkspaceFromCache();
+    if (!workspace) {
+      return;
+    }
+    const { KavachaSpaceHistory } = ChromeUtils.importESModule(
+      "resource:///modules/KavachaSpaceHistory.sys.mjs"
+    );
+    const snapshots = await KavachaSpaceHistory.listSnapshots(workspace.uuid);
+
+    const panel = document.getElementById("kavacha-timeline-panel");
+    document.l10n.setAttributes(
+      document.getElementById("kavacha-timeline-title"),
+      "kavacha-timeline-title",
+      { name: workspace.name }
+    );
+    document.getElementById("kavacha-timeline-empty").hidden =
+      !!snapshots.length;
+
+    const list = document.getElementById("kavacha-timeline-list");
+    list.textContent = "";
+    const fmt = new Intl.DateTimeFormat(undefined, {
+      dateStyle: "medium",
+      timeStyle: "short",
+    });
+    const restoreLabel = await document.l10n.formatValue(
+      "kavacha-timeline-restore"
+    );
+    for (const snap of snapshots) {
+      const row = document.createXULElement("hbox");
+      row.setAttribute("align", "center");
+      row.style.gap = "8px";
+      const label = document.createXULElement("label");
+      label.setAttribute("flex", "1");
+      label.style.opacity = "0.9";
+      label.value = `${fmt.format(new Date(snap.createdAt))} · ${snap.tabCount} tabs · ${snap.reason}`;
+      const btn = document.createXULElement("button");
+      btn.setAttribute("label", restoreLabel);
+      btn.addEventListener("command", () => {
+        panel.hidePopup();
+        this.kavachaBranchSpace(snap.id).catch(e =>
+          console.error("kavachaOpenSpaceTimeline: restore failed", e)
+        );
+      });
+      row.append(label, btn);
+      list.append(row);
+    }
+
+    const anchor = this.workspaceIcons || gURLBar.textbox;
+    panel.openPopup(anchor, "after_start", 0, 0, false, false);
+  }
+
   #flushWorkspaceNotes() {
     const panel = document.getElementById("kavacha-notes-panel");
     const uuid = panel.getAttribute("data-workspace-id");
