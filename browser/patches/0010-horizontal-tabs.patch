diff --git a/src/zen/tabs/zen-tabs/kavacha-horizontal-tabs.inc.css b/src/zen/tabs/zen-tabs/kavacha-horizontal-tabs.inc.css
new file mode 100644
index 0000000..1c05fa1
--- /dev/null
+++ b/src/zen/tabs/zen-tabs/kavacha-horizontal-tabs.inc.css
@@ -0,0 +1,441 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/* ==========================================================================
+   Kavacha: horizontal tabs mode (`zen.tabs.vertical` = false)
+
+   Zen's JS fully supports horizontal orientation (ZenUIManager flips the
+   tab-strip orient and merges the toolbars when the pref is false), but the
+   stylesheet hard-codes the vertical sidebar. This layer restores a top-bar
+   layout: URL-bar row on top (single-toolbar mode is forced by JS when
+   horizontal), tab strip row below it, web content underneath.
+   ========================================================================== */
+/* stylelint-disable-next-line media-query-no-invalid */
+@media not -moz-pref("zen.tabs.vertical") {
+  /* The window becomes a column: toolbox bar on top, content below. */
+  #browser {
+    flex-direction: column;
+  }
+
+  /* The sidebar resize splitter has no sidebar to resize — and left in flow
+     it stretches to fill the column, shoving the content to the bottom. */
+  #zen-sidebar-splitter {
+    display: none !important;
+  }
+
+  /* Web content takes everything under the bar — the XUL flex chain was
+     tuned for the row layout and collapses to zero height in a column. */
+  #zen-appcontent-wrapper {
+    flex: 1 1 auto !important;
+    min-height: 0;
+    width: 100%;
+  }
+
+  #zen-tabbox-wrapper,
+  #tabbrowser-tabbox,
+  #tabbrowser-tabpanels {
+    flex: 1 1 auto !important;
+    min-height: 0;
+    height: auto !important;
+  }
+
+  /* Chrome-convention ordering: tab strip on the very top row, URL bar row
+     under it with the app menu / extensions on its right. Wrapping row flex
+     lets nav-bar and the (former sidebar) top-buttons share the second row. */
+  #navigator-toolbox {
+    width: 100% !important;
+    max-width: none !important;
+    min-width: 0 !important;
+    height: auto !important;
+    flex: none !important;
+    flex-direction: row !important;
+    flex-wrap: wrap !important;
+    padding: 0 !important;
+  }
+
+  #titlebar {
+    order: -1;
+    width: 100% !important;
+  }
+
+  /* Nav buttons are moved into the nav bar by ZenStartup (patched); the
+     remaining top-buttons (app menu, extensions) sit at the row's right,
+     Chrome-style. */
+  #zen-sidebar-top-buttons {
+    order: 2;
+    flex: 0 0 auto !important;
+    /* The element carries flex="1", which xul.css maps to flex:1 1 0%
+       with UA-!important — unbeatable from author CSS (ZenUIManager,
+       patched, removes the attribute; this caps the first paint). */
+    max-width: fit-content !important;
+    width: auto !important;
+    min-width: 0 !important;
+    height: auto !important;
+    align-items: center;
+  }
+
+  #zen-sidebar-top-buttons-customization-target {
+    flex: 0 0 auto !important;
+    width: auto !important;
+    max-width: fit-content !important;
+    flex-direction: row !important;
+    align-items: center;
+  }
+
+  #nav-bar {
+    order: 1;
+    flex: 1 1 auto !important;
+    width: auto !important;
+    min-width: 0;
+  }
+
+  /* Standard browser URL row: nav icons on the left, URL bar filling the
+     remaining window width, menu/extensions at the far right. */
+  #nav-bar {
+    padding: 2px 8px !important;
+  }
+
+  #nav-bar #nav-bar-customization-target {
+    flex: 1 1 auto;
+    align-items: center;
+  }
+
+  #nav-bar #urlbar-container {
+    flex: 1 1 auto !important;
+    width: auto !important;
+    max-width: none !important;
+    min-width: 0;
+  }
+
+  /* The urlbar is a top-layer POPOVER: Firefox syncs its width to
+     #urlbar-container (ResizeObserver -> --urlbar-width) and its x/y come
+     from the static position of its DOM slot, so with the container
+     filling the row it aligns itself — don't override its geometry (a
+     width/left/top pin resolves against the viewport and paints it over
+     the nav buttons and traffic lights). Zen's detached float
+     ([zen-floating-urlbar], Cmd+T) is likewise viewport-anchored and
+     centers itself (left 50% / --zen-urlbar-top) — leave it alone too. */
+
+  /* Compact mode slides #navigator-toolbox off-screen (position:fixed +
+     negative left) for the vertical sidebar's hover reveal — with a top
+     bar that just removes the whole UI. Keep the toolbox in flow; compact
+     mode becomes a no-op in horizontal until a real auto-hide top bar. */
+  #navigator-toolbox {
+    position: relative !important;
+    left: auto !important;
+    top: auto !important;
+    transform: none !important;
+  }
+
+  /* Breathing room at the window edges. */
+  #titlebar {
+    padding-right: 10px;
+  }
+
+  #TabsToolbar > .toolbar-items {
+    padding-left: 2px;
+  }
+
+  /* macOS: the native traffic lights are POSITIONED to match the buttonbox
+     element's geometry, so it must live in normal flow inside the tab strip
+     row — ZenStartup (patched) moves it into #TabsToolbar in horizontal
+     mode. Just size it here. */
+  @media (-moz-platform: macos) {
+    #TabsToolbar > .titlebar-buttonbox-container {
+      display: flex !important;
+      width: 78px;
+      align-items: center;
+      justify-content: center;
+    }
+  }
+
+  /* Sidebar notifications (e.g. the post-update card) anchor next to the
+     media toolbar inside the strip — float them as a dismissable card
+     instead of an unclickable sliver. */
+  zen-sidebar-notification {
+    position: fixed !important;
+    top: 100px;
+    right: 16px;
+    width: 320px !important;
+    max-width: 320px !important;
+    height: auto !important;
+    max-height: none !important;
+    z-index: 1000;
+  }
+
+  /* Media controls (user report 2026-07-15): Zen designs this toolbar for
+     the sidebar's bottom-left and leaves it transparent — the sidebar
+     provides the surface. Inline in the 44px strip it compressed into a
+     sliver at the top right. Float it where Zen puts it visually, bottom
+     left over the content, and give the now-surfaceless toolbar its own
+     card (panel tokens follow the active theme). Height stays auto so the
+     hover-revealed title/progress rows grow the card upward from the
+     pinned bottom edge. */
+  #zen-media-controls-toolbar:not([hidden]) {
+    position: fixed !important;
+    bottom: 16px;
+    left: 16px;
+    width: 320px !important;
+    height: auto !important;
+    padding: 10px 12px;
+    border-radius: 12px;
+    background: var(--arrowpanel-background);
+    color: var(--arrowpanel-color);
+    border: 1px solid var(--arrowpanel-border-color);
+    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
+    z-index: 1000;
+  }
+
+  /* Undo the unconditional vertical stacking of the strip chain, and pin the
+     row to one strip-height: .toolbar-items carries XUL align="end", so any
+     oversized child inflates the row and sinks the tab area below the
+     visible strip (clipped tabs). Cap + center instead. */
+  #titlebar,
+  #TabsToolbar,
+  #TabsToolbar > .toolbar-items,
+  #TabsToolbar-customization-target {
+    flex-direction: row !important;
+    height: var(--kavacha-horizontal-strip-height, 44px) !important;
+    max-height: var(--kavacha-horizontal-strip-height, 44px) !important;
+    align-items: center !important;
+    width: 100%;
+  }
+
+  /* Essentials (pinned favorites) sit inline at the strip's start instead of
+     stretching to the sidebar's full width (their vertical-mode min-width is
+     100%+padding, which starves everything else in a row). */
+  #zen-essentials {
+    width: auto !important;
+    min-width: 0 !important;
+    margin-left: 0 !important;
+    flex: 0 0 auto;
+  }
+
+  #zen-essentials {
+    display: flex !important;
+    flex-direction: row;
+    align-items: center;
+  }
+
+  /* Inactive container-contexts keep their essentials section hidden via
+     position:fixed + visibility:hidden — drop them from layout entirely
+     rather than un-fixing them into the strip. */
+  #zen-essentials .zen-essentials-container[hidden="true"] {
+    display: none !important;
+  }
+
+  #zen-essentials .zen-essentials-container:not([hidden="true"]) {
+    display: flex !important;
+    flex-direction: row !important;
+    align-items: center;
+    position: static !important;
+    width: auto !important;
+    min-width: 0 !important;
+    max-height: 100% !important;
+    padding: 0 !important;
+    gap: 2px;
+  }
+
+  /* Essentials are favicon-only squares in the strip. */
+  #zen-essentials .tabbrowser-tab {
+    width: 36px !important;
+    min-width: 36px !important;
+    max-width: 36px !important;
+    height: 36px;
+  }
+
+  /* The strip needs a definite height: zen-workspace panes are absolutely
+     positioned (the slide-switch animation) and size to this box. The
+     wrapper is the flex item that takes the row's free space. */
+  #zen-tabs-wrapper {
+    height: var(--kavacha-horizontal-strip-height, 42px);
+    min-height: var(--kavacha-horizontal-strip-height, 42px);
+    flex: 1 1 auto;
+    min-width: 0;
+    width: auto;
+    position: relative;
+    overflow: visible;
+  }
+
+  /* The main tab scrollbox chain must be a row too (its orient attribute
+     stays vertical except on the element Zen's JS touched at startup). */
+  #tabbrowser-arrowscrollbox {
+    flex-direction: row !important;
+    max-height: 100% !important;
+    height: 100%;
+  }
+
+  #tabbrowser-arrowscrollbox::part(scrollbox) {
+    flex-direction: row !important;
+  }
+
+  /* In a row toolbar the tabs container must claim the free space — vertical
+     mode never needed a flex basis (the column was sized by the sidebar).
+     The sidebar foot buttons (downloads / space icons / new tab) otherwise
+     hog the whole row at their vertical-mode 100% width; pin them to content
+     size so they sit at the strip's right end. */
+  #TabsToolbar > .toolbar-items {
+    flex: 1 !important;
+    min-width: 0;
+  }
+
+  #zen-sidebar-foot-buttons {
+    width: auto !important;
+    flex: 0 0 auto !important;
+  }
+
+  /* The space icon strip is width:100% of the (now auto-width) foot buttons
+     — circular, collapses to 0 and removes the only click target for
+     switching spaces. Its container-type:inline-size also makes intrinsic
+     sizing ignore the icons, so drop the containment and size to content. */
+  #zen-workspaces-button {
+    container-type: normal !important;
+    width: auto !important;
+    min-width: fit-content;
+  }
+
+  #TabsToolbar-customization-target {
+    flex: 1;
+    min-width: 0;
+  }
+
+  #tabbrowser-tabs {
+    flex: 1 !important;
+    min-width: 0;
+    flex-direction: row !important;
+    height: 100%;
+    width: 100%;
+  }
+
+  /* Workspace panes: keep the absolute + translateX slide mechanism, but
+     lay their content out in a row. Vertical mode pads the pane top for the
+     workspace indicator — that padding pushes tabs below the strip here. */
+  zen-workspace {
+    flex-direction: row !important;
+    height: 100% !important;
+    width: 100% !important;
+    align-items: center;
+    padding-top: 0 !important;
+    padding-bottom: 0 !important;
+  }
+
+  zen-workspace > arrowscrollbox {
+    width: 100%;
+    height: 100%;
+    max-height: none;
+  }
+
+  zen-workspace .zen-workspace-tabs-section {
+    height: 100%;
+    align-items: center;
+  }
+
+  /* The arrowscrollbox shadow scrollbox follows its `orient` attribute,
+     which Zen's JS only flips on the active workspace at startup — force
+     row layout for every workspace's strip regardless. */
+  zen-workspace arrowscrollbox::part(scrollbox),
+  .workspace-arrowscrollbox::part(scrollbox) {
+    flex-direction: row !important;
+    align-items: center;
+  }
+
+  .zen-workspace-tabs-section {
+    flex-direction: row !important;
+    width: auto !important;
+    height: 100% !important;
+    align-items: center;
+  }
+
+  /* The pinned section sizes to its pinned tabs only (it otherwise claims
+     sidebar-mode free space and indents the normal tabs). */
+  .zen-workspace-pinned-tabs-section {
+    flex: 0 0 auto !important;
+    min-width: 0 !important;
+  }
+
+  /* The pinned-section separator is a sidebar affordance (a 22px rule that
+     stacks above the tabs); drop it in a single-row strip. */
+  .pinned-tabs-container-separator {
+    display: none !important;
+  }
+
+  /* New-tab button belongs after the tabs, not before them. */
+  #tabbrowser-arrowscrollbox-periphery {
+    order: 9999;
+  }
+
+  /* Sidebar-only chrome that has no place in a top bar. Note: hiding the
+     current-workspace indicator removes its right-click affordance; space
+     actions stay reachable from the icon strip / command palette. */
+  .zen-current-workspace-indicator,
+  .zen-workspace-empty-space,
+  #zen-sidebar-top-buttons-separator {
+    display: none !important;
+  }
+
+  /* Standard horizontal tab sizing instead of full-width sidebar rows. */
+  .tabbrowser-tab {
+    width: auto !important;
+    min-width: 100px;
+    max-width: 225px;
+  }
+
+  .tabbrowser-tab .tab-background {
+    width: auto;
+  }
+
+  /* Window dragging: empty areas of both bar rows move the window, like
+     every horizontal-tab browser. Interactive pieces opt back out (tabs
+     keep their own drag-to-reorder; the native buttonbox manages itself). */
+  #titlebar,
+  #TabsToolbar,
+  #TabsToolbar > .toolbar-items,
+  #TabsToolbar-customization-target,
+  #zen-tabs-wrapper,
+  zen-workspace,
+  zen-workspace arrowscrollbox,
+  #nav-bar,
+  #nav-bar-customization-target {
+    -moz-window-dragging: drag;
+  }
+
+  .tabbrowser-tab,
+  toolbarbutton,
+  #urlbar,
+  #zen-sidebar-foot-buttons,
+  #zen-sidebar-top-buttons,
+  #TabsToolbar > .titlebar-buttonbox-container {
+    -moz-window-dragging: no-drag;
+  }
+
+  /* The space-creation pane is a full-height sidebar UI; inside the 44px
+     strip it renders clipped above the window (y < 0) and "New Space"
+     looks dead. Float it as a centered card instead. */
+  zen-workspace-creation {
+    position: fixed !important;
+    top: max(96px, 14vh);
+    left: 50%;
+    translate: -50% 0;
+    display: flex !important;
+    flex-direction: column !important;
+    width: min(460px, 90vw) !important;
+    /* the host doesn't size to its form content on its own */
+    height: fit-content !important;
+    min-height: fit-content !important;
+    max-width: none !important;
+    max-height: 70vh;
+    z-index: 1000;
+    padding: 20px !important;
+    overflow: auto;
+    background: var(--arrowpanel-background, light-dark(#fff, #2b2a33));
+    color: var(--arrowpanel-color, inherit);
+    border: 1px solid
+      var(
+        --arrowpanel-border-color,
+        color-mix(in srgb, currentColor 20%, transparent)
+      );
+    border-radius: 12px;
+    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.4);
+  }
+}
