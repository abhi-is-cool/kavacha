+      if (idx === -1) {
+        workspace.extensions.push(addonId);
+      } else {
+        workspace.extensions.splice(idx, 1);
+      }
+    }
+    this.saveWorkspace(workspace);
+    if (this.isWorkspaceActive(workspace)) {
+      await this.applyWorkspaceExtensions(workspace);
+    }
+  }
