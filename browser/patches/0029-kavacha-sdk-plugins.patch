diff --git a/src/zen/kavacha-plugins/plugins.css b/src/zen/kavacha-plugins/plugins.css
new file mode 100644
index 0000000..eeda84d
--- /dev/null
+++ b/src/zen/kavacha-plugins/plugins.css
@@ -0,0 +1,267 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/* about:plugins — the plugin manager. Styled from the same Kavacha/Zen chrome
+ * tokens as the Customization Studio (studio.css) so it follows the active
+ * theme (patch 0016 bakes the Midnight floor; the theme engine, patch 0023,
+ * re-tints --kavacha-* live). ADR 0011. */
+
+:root {
+  --pl-surface: var(--kavacha-surface, #14111f);
+  --pl-elevated: var(--kavacha-surface-elevated, #1d1930);
+  --pl-sunken: var(--kavacha-surface-sunken, #0e0b18);
+  --pl-border: var(--kavacha-border, #2e2846);
+  --pl-text: var(--kavacha-text-primary, #edeaf7);
+  --pl-text-dim: var(--kavacha-text-secondary, #a79fc4);
+  --pl-accent: var(--zen-primary-color, var(--kavacha-accent, #8b7bd8));
+  --pl-danger: #e06c75;
+  color-scheme: dark;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  padding: 0 0 64px;
+  font: message-box;
+  font-size: 15px;
+  line-height: 1.5;
+  color: var(--pl-text);
+  background: var(--pl-surface);
+  min-height: 100vh;
+}
+
+.plugins-header {
+  padding: 40px max(24px, 50% - 460px) 24px;
+  background: linear-gradient(
+    180deg,
+    var(--pl-elevated),
+    var(--pl-surface)
+  );
+  border-bottom: 1px solid var(--pl-border);
+}
+
+.plugins-title h1 {
+  margin: 0;
+  font-size: 28px;
+  font-weight: 700;
+  letter-spacing: -0.01em;
+}
+
+.plugins-subtitle {
+  margin: 6px 0 0;
+  color: var(--pl-text-dim);
+  max-width: 60ch;
+}
+
+.plugins-body {
+  padding: 28px max(24px, 50% - 460px) 0;
+  max-width: 920px;
+  margin: 0 auto;
+}
+
+.plugins-note {
+  background: var(--pl-sunken);
+  border: 1px solid var(--pl-border);
+  border-radius: 12px;
+  padding: 14px 16px;
+  color: var(--pl-text-dim);
+  font-size: 13px;
+  margin-bottom: 20px;
+}
+
+.plugins-note code,
+.plugins-empty code {
+  font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
+  font-size: 12px;
+  color: var(--pl-text);
+}
+
+.plugins-empty {
+  color: var(--pl-text-dim);
+  font-size: 14px;
+  padding: 8px 2px;
+}
+
+.plugin-list {
+  display: flex;
+  flex-direction: column;
+  gap: 18px;
+}
+
+.plugin-card {
+  background: var(--pl-elevated);
+  border: 1px solid var(--pl-border);
+  border-radius: 14px;
+  padding: 20px 22px;
+}
+
+.plugin-card-head {
+  display: flex;
+  align-items: flex-start;
+  justify-content: space-between;
+  gap: 16px;
+  flex-wrap: wrap;
+}
+
+.plugin-name {
+  margin: 0;
+  font-size: 17px;
+  font-weight: 650;
+}
+
+.plugin-meta {
+  margin: 2px 0 0;
+  color: var(--pl-text-dim);
+  font-size: 12px;
+}
+
+.plugin-desc {
+  margin: 10px 0 0;
+  color: var(--pl-text-dim);
+  font-size: 13px;
+  max-width: 62ch;
+}
+
+/* Enable/disable toggle */
+.plugin-toggle {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  flex-shrink: 0;
+  font-size: 13px;
+  font-weight: 600;
+  color: var(--pl-text-dim);
+  cursor: pointer;
+}
+
+.plugin-toggle input {
+  accent-color: var(--pl-accent);
+  width: 16px;
+  height: 16px;
+}
+
+.plugin-toggle[data-enabled="true"] {
+  color: var(--pl-text);
+}
+
+/* Permissions */
+.plugin-perms {
+  margin-top: 16px;
+  border-top: 1px solid var(--pl-border);
+  padding-top: 14px;
+}
+
+.plugin-perms h3 {
+  margin: 0 0 4px;
+  font-size: 13px;
+  font-weight: 650;
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+  color: var(--pl-text-dim);
+}
+
+.perm-row {
+  display: flex;
+  align-items: flex-start;
+  gap: 10px;
+  padding: 10px 0;
+  border-bottom: 1px solid var(--pl-border);
+}
+
+.perm-row:last-child {
+  border-bottom: none;
+}
+
+.perm-row input {
+  accent-color: var(--pl-accent);
+  width: 16px;
+  height: 16px;
+  margin-top: 2px;
+  flex-shrink: 0;
+}
+
+.perm-copy {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+  min-width: 0;
+}
+
+.perm-name {
+  font-weight: 600;
+  font-size: 13px;
+  text-transform: capitalize;
+}
+
+.perm-desc {
+  color: var(--pl-text-dim);
+  font-size: 12px;
+}
+
+.plugin-none-requested {
+  color: var(--pl-text-dim);
+  font-size: 13px;
+  margin: 4px 0 0;
+}
+
+/* Actions */
+.plugin-actions {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  margin-top: 16px;
+  flex-wrap: wrap;
+}
+
+.plugin-status {
+  color: var(--pl-text-dim);
+  font-size: 13px;
+  role: status;
+}
+
+.pl-button {
+  appearance: none;
+  font: inherit;
+  font-weight: 600;
+  border-radius: 10px;
+  padding: 9px 16px;
+  cursor: pointer;
+  border: 1px solid var(--pl-border);
+  background: transparent;
+  color: var(--pl-text-dim);
+}
+
+.pl-button:hover {
+  color: var(--pl-text);
+  background: var(--pl-sunken);
+}
+
+.pl-button.primary {
+  background: var(--pl-accent);
+  color: #fff;
+  border-color: transparent;
+}
+
+.pl-button.primary:hover {
+  filter: brightness(1.08);
+  background: var(--pl-accent);
+  color: #fff;
+}
+
+.pl-button.danger {
+  color: var(--pl-danger);
+  border-color: color-mix(in srgb, var(--pl-danger) 45%, var(--pl-border));
+}
+
+.pl-button.danger:hover {
+  color: #fff;
+  background: var(--pl-danger);
+}
+
+.pl-button.ghost {
+  margin-inline-start: auto;
+}
diff --git a/src/zen/kavacha-plugins/plugins.html b/src/zen/kavacha-plugins/plugins.html
