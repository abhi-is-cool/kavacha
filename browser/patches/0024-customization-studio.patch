diff --git a/src/zen/kavacha-studio/studio.css b/src/zen/kavacha-studio/studio.css
new file mode 100644
index 0000000..c50b6e2
--- /dev/null
+++ b/src/zen/kavacha-studio/studio.css
@@ -0,0 +1,292 @@
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/* Customization Studio (about:studio). Styled from Kavacha/Zen chrome tokens
+ * so the Studio itself follows the active theme (patch 0016 bakes the Midnight
+ * floor; the theme engine, patch 0023, re-tints --kavacha-* live). ADR 0009. */
+
+:root {
+  --studio-surface: var(--kavacha-surface, #14111f);
+  --studio-elevated: var(--kavacha-surface-elevated, #1d1930);
+  --studio-sunken: var(--kavacha-surface-sunken, #0e0b18);
+  --studio-border: var(--kavacha-border, #2e2846);
+  --studio-text: var(--kavacha-text-primary, #edeaf7);
+  --studio-text-dim: var(--kavacha-text-secondary, #a79fc4);
+  --studio-accent: var(--zen-primary-color, var(--kavacha-accent, #8b7bd8));
+  color-scheme: dark;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  margin: 0;
+  padding: 0 0 64px;
+  font: message-box;
+  font-size: 15px;
+  line-height: 1.5;
+  color: var(--studio-text);
+  background: var(--studio-surface);
+  min-height: 100vh;
+}
+
+.studio-header {
+  padding: 40px max(24px, 50% - 460px) 24px;
+  background: linear-gradient(
+    180deg,
+    var(--studio-elevated),
+    var(--studio-surface)
+  );
+  border-bottom: 1px solid var(--studio-border);
+}
+
+.studio-title h1 {
+  margin: 0;
+  font-size: 28px;
+  font-weight: 700;
+  letter-spacing: -0.01em;
+}
+
+.studio-subtitle {
+  margin: 6px 0 0;
+  color: var(--studio-text-dim);
+  max-width: 52ch;
+}
+
+.studio-tabs {
+  display: flex;
+  gap: 4px;
+  padding: 0 max(24px, 50% - 460px);
+  border-bottom: 1px solid var(--studio-border);
+  background: var(--studio-surface);
+  position: sticky;
+  top: 0;
+  z-index: 2;
+}
+
+.studio-tab {
+  appearance: none;
+  border: none;
+  background: none;
+  color: var(--studio-text-dim);
+  font: inherit;
+  font-weight: 600;
+  padding: 14px 16px;
+  cursor: pointer;
+  border-bottom: 2px solid transparent;
+  margin-bottom: -1px;
+}
+
+.studio-tab:hover {
+  color: var(--studio-text);
+}
+
+.studio-tab[aria-selected="true"] {
+  color: var(--studio-text);
+  border-bottom-color: var(--studio-accent);
+}
+
+.studio-body {
+  padding: 28px max(24px, 50% - 460px) 0;
+  max-width: 920px;
+  margin: 0 auto;
+}
+
+.studio-panel[hidden] {
+  display: none;
+}
+
+.studio-card {
+  background: var(--studio-elevated);
+  border: 1px solid var(--studio-border);
+  border-radius: 14px;
+  padding: 20px 22px;
+  margin-bottom: 18px;
+}
+
+.studio-card[data-requires][hidden] {
+  display: none;
+}
+
+.studio-card h2 {
+  margin: 0 0 4px;
+  font-size: 17px;
+  font-weight: 650;
+}
+
+.studio-hint {
+  margin: 0 0 14px;
+  color: var(--studio-text-dim);
+  font-size: 13px;
+}
+
+.field {
+  display: flex;
+  align-items: center;
+  gap: 14px;
+  margin-top: 14px;
+  flex-wrap: wrap;
+}
+
+.field-label {
+  min-width: 76px;
+  color: var(--studio-text-dim);
+  font-size: 13px;
+  font-weight: 600;
+}
+
+/* Segmented radio-button group */
+.segmented {
+  display: inline-flex;
+  background: var(--studio-sunken);
+  border: 1px solid var(--studio-border);
+  border-radius: 10px;
+  padding: 3px;
+  gap: 2px;
+}
+
+.segmented button {
+  appearance: none;
+  border: none;
+  background: none;
+  color: var(--studio-text-dim);
+  font: inherit;
+  font-size: 13px;
+  font-weight: 600;
+  padding: 7px 14px;
+  border-radius: 7px;
+  cursor: pointer;
+}
+
+.segmented button:hover {
+  color: var(--studio-text);
+}
+
+.segmented button[aria-checked="true"] {
+  background: var(--studio-accent);
+  color: #fff;
+}
+
+input[type="range"] {
+  flex: 1;
+  min-width: 160px;
+  accent-color: var(--studio-accent);
+}
+
+output {
+  font-variant-numeric: tabular-nums;
+  color: var(--studio-text-dim);
+  min-width: 52px;
+  text-align: right;
+}
+
+.checkbox-row {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  margin-top: 16px;
+  cursor: pointer;
+}
+
+.checkbox-row input {
+  accent-color: var(--studio-accent);
+  width: 16px;
+  height: 16px;
+}
+
+.studio-actions {
+  margin: 4px 0 24px;
+}
+
+.studio-button {
+  appearance: none;
+  font: inherit;
+  font-weight: 600;
+  border-radius: 10px;
+  padding: 10px 18px;
+  cursor: pointer;
+  border: 1px solid var(--studio-border);
+}
+
+.studio-button.ghost {
+  background: transparent;
+  color: var(--studio-text-dim);
+}
+
+.studio-button.ghost:hover {
+  color: var(--studio-text);
+  background: var(--studio-elevated);
+}
+
+.studio-button.primary {
+  background: var(--studio-accent);
+  color: #fff;
+  border-color: transparent;
+}
+
+.studio-button.primary:hover {
+  filter: brightness(1.08);
+}
+
+/* Theme grid */
+.theme-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
+  gap: 14px;
+}
+
+.theme-card {
+  appearance: none;
+  text-align: left;
+  border: 2px solid var(--studio-border);
+  border-radius: 12px;
+  padding: 0;
+  overflow: hidden;
+  background: var(--studio-sunken);
+  color: var(--studio-text);
+  cursor: pointer;
+  font: inherit;
+}
+
+.theme-card:hover {
+  border-color: var(--studio-text-dim);
+}
+
+.theme-card[aria-checked="true"] {
+  border-color: var(--studio-accent);
+}
+
+.theme-swatch {
+  height: 68px;
+  display: flex;
+}
+
+.theme-swatch span {
+  flex: 1;
+}
+
+.theme-meta {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 10px 12px;
+}
+
+.theme-name {
+  font-weight: 600;
+  font-size: 13px;
+}
+
+.theme-active-badge {
+  font-size: 11px;
+  font-weight: 700;
+  color: var(--studio-accent);
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+}
+
+.theme-card:not([aria-checked="true"]) .theme-active-badge {
+  display: none;
+}
diff --git a/src/zen/kavacha-studio/studio.html b/src/zen/kavacha-studio/studio.html
new file mode 100644
index 0000000..7dcdb49
--- /dev/null
+++ b/src/zen/kavacha-studio/studio.html
@@ -0,0 +1,148 @@
+<!-- This Source Code Form is subject to the terms of the Mozilla Public
+   - License, v. 2.0. If a copy of the MPL was not distributed with this
+   - file, You can obtain one at http://mozilla.org/MPL/2.0/. -->
+<!DOCTYPE html>
+<html lang="en" dir="ltr">
+  <head>
+    <meta charset="utf-8" />
+    <meta
+      http-equiv="Content-Security-Policy"
+      content="default-src chrome:; img-src chrome: data:; style-src chrome: 'unsafe-inline'; object-src 'none'"
+    />
+    <title>Customization Studio</title>
+    <link rel="stylesheet" href="chrome://browser/content/kavacha-studio/studio.css" />
+    <script src="chrome://browser/content/kavacha-studio/studio.js"></script>
+  </head>
+  <body>
+    <header class="studio-header">
+      <div class="studio-title">
+        <h1>Customization Studio</h1>
+        <p class="studio-subtitle">
+          Redesign your browser — no CSS required. Changes apply live to every
+          window.
+        </p>
+      </div>
+    </header>
+
+    <nav class="studio-tabs" role="tablist" aria-label="Studio sections">
+      <button
+        id="tab-layout"
+        class="studio-tab"
+        role="tab"
+        aria-selected="true"
+        aria-controls="panel-layout"
+        data-tab="layout"
+      >
+        Layout
+      </button>
+      <button
+        id="tab-themes"
+        class="studio-tab"
+        role="tab"
+        aria-selected="false"
+        aria-controls="panel-themes"
+        data-tab="themes"
+      >
+        Themes
+      </button>
+    </nav>
+
+    <main class="studio-body">
+      <!-- ============================ LAYOUT ============================ -->
+      <section
+        id="panel-layout"
+        class="studio-panel"
+        role="tabpanel"
+        aria-labelledby="tab-layout"
+      >
+        <div class="studio-card">
+          <h2>Tabs</h2>
+          <p class="studio-hint">
+            Horizontal is Kavacha's default. Vertical brings back a sidebar
+            strip.
+          </p>
+          <div class="segmented" role="radiogroup" aria-label="Tab layout" data-control="tabStyle">
+            <button role="radio" data-value="horizontal">Horizontal</button>
+            <button role="radio" data-value="vertical">Vertical</button>
+          </div>
+        </div>
+
+        <div class="studio-card" data-requires="vertical">
+          <h2>Sidebar</h2>
+          <p class="studio-hint">Only applies while tabs are vertical.</p>
+          <div class="field">
+            <span class="field-label">Position</span>
+            <div class="segmented" role="radiogroup" aria-label="Sidebar position" data-control="sidebar">
+              <button role="radio" data-value="left">Left</button>
+              <button role="radio" data-value="right">Right</button>
+              <button role="radio" data-value="hidden">Hidden</button>
+            </div>
+          </div>
+          <div class="field">
+            <label class="field-label" for="sidebar-width">Width</label>
+            <input
+              id="sidebar-width"
+              type="range"
+              min="48"
+              max="600"
+              step="1"
+              data-control="sidebarWidth"
+            />
+            <output id="sidebar-width-value" for="sidebar-width">250px</output>
+          </div>
+        </div>
+
+        <div class="studio-card">
+          <h2>Density</h2>
+          <p class="studio-hint">Breathing room around tabs and controls.</p>
+          <div class="segmented" role="radiogroup" aria-label="Interface density" data-control="density">
+            <button role="radio" data-value="compact">Compact</button>
+            <button role="radio" data-value="normal">Normal</button>
+            <button role="radio" data-value="comfortable">Comfortable</button>
+          </div>
+        </div>
+
+        <div class="studio-card">
+          <h2>Toolbar</h2>
+          <div class="field">
+            <span class="field-label">Position</span>
+            <div class="segmented" role="radiogroup" aria-label="Toolbar position" data-control="toolbarPosition">
+              <button role="radio" data-value="top">Top</button>
+              <button role="radio" data-value="bottom">Bottom</button>
+            </div>
+          </div>
+          <label class="checkbox-row">
+            <input type="checkbox" data-control="toolbarVisible" />
+            <span>Show the navigation toolbar</span>
+          </label>
+        </div>
+
+        <div class="studio-actions">
+          <button id="reset-layout" class="studio-button ghost">
+            Reset layout to default
+          </button>
+        </div>
+      </section>
+
+      <!-- ============================ THEMES ============================ -->
+      <section
+        id="panel-themes"
+        class="studio-panel"
+        role="tabpanel"
+        aria-labelledby="tab-themes"
+        hidden
+      >
+        <div class="studio-card">
+          <h2>Theme</h2>
+          <p class="studio-hint">
+            Themes tint the browser's surfaces. Your accent color stays yours —
+            change it any time from Settings.
+          </p>
+          <div id="theme-grid" class="theme-grid" role="radiogroup" aria-label="Theme">
+            <!-- theme cards injected by studio.js -->
+          </div>
+        </div>
+      </section>
+    </main>
+  </body>
+</html>
