diff --git a/src/zen/common/sys/KavachaNewTab.sys.mjs b/src/zen/common/sys/KavachaNewTab.sys.mjs
new file mode 100644
index 0000000..bee17af
--- /dev/null
+++ b/src/zen/common/sys/KavachaNewTab.sys.mjs
@@ -0,0 +1,41 @@
+// This Source Code Form is subject to the terms of the Mozilla Public
+// License, v. 2.0. If a copy of the MPL was not distributed with this
+// file, You can obtain one at http://mozilla.org/MPL/2.0/.
+
+// Kavacha: route new tabs to the bundled dashboard page when Zen's floating
+// search bar is turned off (Settings > Looks and Feel). Process singleton —
+// windows call init() freely; only the first call wires anything.
+
+const lazy = {};
+ChromeUtils.defineESModuleGetters(lazy, {
+  AboutNewTab: "resource:///modules/AboutNewTab.sys.mjs",
+});
+
+const kFloatingSearchPref = "zen.urlbar.replace-newtab";
+const kDashboardURL = "chrome://browser/content/kavacha-newtab/index.html";
+
+export const KavachaNewTab = {
+  _initialized: false,
+
+  init() {
+    if (this._initialized) {
+      return;
+    }
+    this._initialized = true;
+    Services.prefs.addObserver(kFloatingSearchPref, this);
+    this._apply();
+  },
+
+  observe() {
+    this._apply();
+  },
+
+  _apply() {
+    if (Services.prefs.getBoolPref(kFloatingSearchPref, true)) {
+      // Floating search owns Cmd+T; leave about:newtab alone.
+      lazy.AboutNewTab.resetNewTabURL();
+    } else {
+      lazy.AboutNewTab.newTabURL = kDashboardURL;
+    }
+  },
+};
